function cmd_build_al2() {
    podman build \
	   -t lustre-al2 \
	   -f ci-lustre/Containerfile.al2 \
	   .
    podman run \
	   -it \
	   --workdir /home/root/git/lustre-release/ \
	   --pids-limit 100000 \
	   --tty --interactive=false \
	   -v /home/admin/Programming/lustre-release/:/home/root/git/lustre-release/:O \
	   --rm lustre-al2:latest \
	   bash -c '
pwd
echo "Running tests..."
./autogen.sh
./configure
make -j$(nproc)
       '
}

# parse command and shift for rest of arg parsing
CMD="$1"
shift

# check if command is valid
if [[ $(type -t "cmd_$CMD") == function ]]; then
    CMD="cmd_$CMD"
else
    usage
    exit 1
fi

while getopts "w:h" arg; do
    case $arg in
	w)
	    ktest_workdir="$OPTARG"
	    ;;
	h)
	    usage
	    exit 0
	    ;;
    esac
done
shift $((OPTIND - 1))

$CMD "$@"
