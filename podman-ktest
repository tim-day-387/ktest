	   .
    podman run \
	   -it \
	   --workdir /home/root/git/lustre-release/ \
	   --pids-limit 100000 \
	   --tty --interactive=false \
	   -v /home/admin/Programming/lustre-release/:/home/root/git/lustre-release/:O \
	   --rm lustre-al2023:latest \
	   bash -c '
pwd
echo "Running tests..."
./autogen.sh
./configure
make -j$(nproc)
       '
