From fb4cdab3e52008bb4dbe9596a9705795857406e5 Mon Sep 17 00:00:00 2001
From: Timothy Day <timday@thelustrecollective.com>
Date: Sat, 6 Jun 2026 23:41:05 -0400
Subject: [PATCH] LU-20335 misc: remove __GFP_HIGHMEM from __vmalloc() callers

Linux commit 07003531e037 ("mm/vmalloc: warn on invalid vmalloc gfp
flags") enforces the set of gfp flags the vmalloc family accepts. Any
unsupported flag now triggers a warning and is stripped:

    +static gfp_t vmalloc_fix_flags(gfp_t flags)
    +{
    +	gfp_t invalid_mask = flags & ~GFP_VMALLOC_SUPPORTED;
    +
    +	flags &= GFP_VMALLOC_SUPPORTED;
    +	WARN_ONCE(1, "Unexpected gfp: %#x (%pGg). Fixing up to gfp: %#x (%pGg). Fix your code!\n",
    +		  invalid_mask, &invalid_mask, flags, &flags);
    +	return flags;
    +}

__GFP_HIGHMEM is not part of GFP_VMALLOC_SUPPORTED, so update various
__vmalloc() callers to stop passing this flag. __vmalloc will use it
automatically since 19809c2da28a ("mm, vmalloc: use __GFP_HIGHMEM
implicitly") which is present in all kernels (v4.12+) that Lustre
supports.

Test-Parameters: trivial
Fixes: 635421641bfa ("LU-5349 include: use __vmalloc() to avoid __GFP_FS default")
Signed-off-by: Timothy Day <timday@thelustrecollective.com>
Change-Id: I917d4c8a27c9754b5393fe1bd9c84a09ae2d74c9
---
 lnet/klnds/gnilnd/gnilnd.h   | 4 ++--
 lustre/include/obd_support.h | 2 +-
 2 files changed, 3 insertions(+), 3 deletions(-)

diff --git a/lnet/klnds/gnilnd/gnilnd.h b/lnet/klnds/gnilnd/gnilnd.h
index 70c7422fda3d..5e203557caa4 100644
--- a/lnet/klnds/gnilnd/gnilnd.h
+++ b/lnet/klnds/gnilnd/gnilnd.h
@@ -994,10 +994,10 @@ static inline void *kgnilnd_vzalloc(int size)
 {
 	void *ret;
 	if (*kgnilnd_tunables.kgn_vzalloc_noretry)
-		ret = __compat_vmalloc(size, __GFP_HIGHMEM | GFP_NOIO |
+		ret = __compat_vmalloc(size, GFP_NOIO |
 				       __GFP_ZERO | __GFP_NORETRY);
 	else
-		ret = __compat_vmalloc(size, __GFP_HIGHMEM | GFP_NOIO |
+		ret = __compat_vmalloc(size, GFP_NOIO |
 				       __GFP_ZERO);
 
 	LIBCFS_ALLOC_POST(ret, size, "alloc");
diff --git a/lustre/include/obd_support.h b/lustre/include/obd_support.h
index e4a1133514aa..02a311323f72 100644
--- a/lustre/include/obd_support.h
+++ b/lustre/include/obd_support.h
@@ -882,7 +882,7 @@ do {									      \
 #define __OBD_VMALLOC_VERBOSE(ptr, cptab, cpt, size)			      \
 do {									      \
 	(ptr) = cptab == NULL ?						      \
-		__compat_vmalloc(size, GFP_NOFS | __GFP_HIGHMEM | __GFP_ZERO) :\
+		__compat_vmalloc(size, GFP_NOFS | __GFP_ZERO) :		      \
 		cfs_cpt_vzalloc(cptab, cpt, size);			      \
 	if (unlikely((ptr) == NULL)) {                                        \
 		CERROR("vmalloc of '" #ptr "' (%d bytes) failed\n",           \
-- 
