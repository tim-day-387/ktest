#!/bin/bash

ktest_dir="$(dirname "$(readlink -f "$0")")/../"

. "$ktest_dir/lib/libktest.sh"

kernel_src_dir="/home/timothy/git/linux/"
kernel_build_dir="/tmp/ktest-out/"
ktest="/home/timothy/ws/ktest/tests/fs/lustre/llmount.ktest"
lustre_src_dir="/home/timothy/git/lustre-release/"

safe_delete_dir() {
    local dir="$1"

    # Check that an argument was provided
    if [ -z "$dir" ]; then
        echo "Error: no directory provided" >&2
        return 1
    fi

    # Check that it exists and is a directory
    if [ ! -d "$dir" ]; then
        echo "Warning: '$dir' does not exist or is not a directory" >&2
        return 0
    fi

    # Safety check: only allow deletion inside /tmp
    case "$dir" in
        /tmp/*)
            if [ "$dir" = "/tmp" ]; then
                echo "Refusing to delete /tmp itself" >&2
                return 1
            fi
            echo "Deleting directory: $dir"
            rm -rf -- "$dir"
            ;;
        *)
            echo "Refusing to delete: '$dir' (not under /tmp)" >&2
            return 1
            ;;
    esac
}

check_file() {
    local file="$1"

    if [[ ! -f "$file" ]]; then
	echo "$file not found!"
	exit 1
    fi

    return 0
}

validate_lustre_build() {
    check_file "$lustre_src_dir/lnet/lnet/lnet.ko"
    check_file "$lustre_src_dir/lustre/llite/lustre.ko"
    check_file "$lustre_src_dir/lustre/osd-wbcfs/osd_wbcfs.ko"
}

build_lustre() {
    cd "$lustre_src_dir"
    git clean -xdf > /dev/null

    echo "PATCH:"
    git log -1 --pretty=%B

    echo "BUILD:"
    ./autogen.sh
    ./configure LLVM="-20" CFLAGS="-Wno-error=attribute-warning" CONFIG_SITE="$ktest_dir/ci-lustre/config.site.ktest"
    make -j$(nproc)

    validate_lustre_build
}

build_lustre_strict() {
    cd "$lustre_src_dir"
    git clean -xdf > /dev/null

    echo "PATCH:"
    git log -1 --pretty=%B

    echo "BUILD:"
    ./autogen.sh
    ./configure LLVM="-20" CONFIG_SITE="$ktest_dir/ci-lustre/config.site.ktest.strict"
    make -j$(nproc)

    validate_lustre_build
}

run_xunused() {
    cd "$lustre_src_dir"
    git clean -xdf > /dev/null

    echo "PATCH:"
    git log -1 --pretty=%B

    echo "BUILD:"
    ./autogen.sh
    ./configure LLVM="-20" CFLAGS="-Wno-error=attribute-warning" CONFIG_SITE="$ktest_dir/ci-lustre/config.site.ktest" --silent
    bear -- make -s -j$(nproc)

    ~/ws/xunused/build/xunused ~/git/lustre-release/compile_commands.json

    validate_lustre_build
}

build_kernel() {
    cd "$kernel_src_dir"
    git clean -xdf > /dev/null
    safe_delete_dir "$kernel_build_dir"

    echo "PATCH:"
    git log -1 --pretty=%B

    cd "$lustre_src_dir"

    echo "KERNEL BUILD:"
    CC=clang-20 FSTYPE=wbcfs /home/timothy/ws/ktest/build-test-kernel build -k "$kernel_src_dir" -o "$kernel_build_dir" "$ktest"
}

while getopts "klsx" arg; do
    case $arg in
	k)
	    build_kernel
	    exit 0
	    ;;
	l)
	    build_lustre
	    exit 0
	    ;;
	s)
	    build_lustre_strict
	    exit 0
	    ;;
	x)
	    run_xunused
	    exit 0
	    ;;
    esac
done

exit -1
