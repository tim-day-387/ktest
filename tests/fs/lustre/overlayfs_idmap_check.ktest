#!/usr/bin/env bash
# SPDX-License-Identifier: GPL-2.0

#
# Build containers/storage and exercise just the overlay driver's
# idmapped-lower-dir feature probe (supportsIdmappedLowerLayers in
# drivers/overlay/check.go) on a Lustre root.
#
# The probe writes its result to $runhome/idmapped-lower-dir-true (on
# success) or $runhome/idmapped-lower-dir-false (on failure), so we
# look for those files to decide pass/fail.
#

. "$(dirname "$(readlink -e "${BASH_SOURCE[0]}")")/lustre-libs.sh"

config-kernel-base "$ktest_dir/config/debian-modules.config"
config-lustre-root

require-lustre-base-kernel-config
require-lustre-builtin-kernel-config
require-kernel-config MODULES=n

# USB boot requires these drivers built-in (no initramfs available)
require-kernel-config USB=y
require-kernel-config USB_XHCI_HCD=y
require-kernel-config USB_XHCI_PCI=y
require-kernel-config USB_EHCI_HCD=y
require-kernel-config USB_EHCI_PCI=y
require-kernel-config USB_STORAGE=y
require-kernel-config SCSI=y
require-kernel-config BLK_DEV_SD=y
require-kernel-config PINCTRL_METEORLAKE=y

require-kernel-config USER_NS
require-kernel-config OVERLAY_FS

config-networking tap
config-mem 10G
config-timeout 180

BUILD_DIR="/ktest_cstorage"
STORAGE_BIN="$BUILD_DIR/storage/containers-storage"

validate_lustre_mount()
{
    local mountpoint="$1"
    local fstype

    fstype=$(findmnt -n -o FSTYPE "$mountpoint")
    if [[ "$fstype" != "lustre" ]]; then
	echo "ERROR: $mountpoint is not Lustre (got '$fstype')"
	return 1
    fi
}

ensure_build()
{
    if [[ -x "$STORAGE_BIN" ]]; then
	echo "Reusing existing build: $STORAGE_BIN"
	return 0
    fi

    if ! command -v go &>/dev/null; then
	echo "Installing dependencies..."
	apt-get update
	apt-get install -y golang-go
    fi

    rm -rf "$BUILD_DIR"
    mkdir -p "$BUILD_DIR"

    export GOCACHE="$BUILD_DIR/gocache"
    export GOPATH="$BUILD_DIR/gopath"

    cd "$BUILD_DIR"
    git clone --depth 1 https://github.com/containers/storage.git
    cd storage

    fstype=$(findmnt -n -o FSTYPE -T .)
    if [[ "$fstype" == "overlay" ]]; then
	echo "ERROR: build dir is overlayfs (got '$fstype'), expected non-overlay"
	exit 1
    fi

    go build -tags exclude_graphdriver_btrfs ./cmd/containers-storage
}

unmount_under()
{
    awk -v p="$1" '$5 ~ "^"p {print $5}' /proc/self/mountinfo |
	tac | while read -r mp; do
	    umount -l "$mp" 2>/dev/null || true
	done
}

run_probe()
{
    local label="$1" graph="$2" run="$3" log="$4"

    rm -rf "$graph" "$run"
    mkdir -p "$graph" "$run"

    local graph_fs
    graph_fs=$(findmnt -n -o FSTYPE -T "$graph")
    if [[ "$graph_fs" != "lustre" ]]; then
	echo "ERROR: $graph is on '$graph_fs', expected lustre"
	return 1
    fi

    dmesg -C

    echo "=== [$label] containers-storage status (debug) ==="
    set +e
    "$STORAGE_BIN" --debug --graph "$graph" --run "$run" \
	--storage-driver overlay status 2>&1 | tee "$log"
    local rc=${PIPESTATUS[0]}
    set -e
    echo "=== [$label] exit=$rc ==="

    local cache_true cache_false
    cache_true=$(find "$run" -name 'idmapped-lower-dir-true' 2>/dev/null | head -1)
    cache_false=$(find "$run" -name 'idmapped-lower-dir-false' 2>/dev/null | head -1)

    echo "=== [$label] dmesg ==="
    dmesg | tail -50

    unmount_under "$graph"
    unmount_under "$run"

    if [[ -n "$cache_true" ]]; then
	echo "[$label] RESULT: idmap probe PASSED on Lustre ($cache_true)"
	rm -rf "$graph" "$run"
	return 0
    fi
    if [[ -n "$cache_false" ]]; then
	echo "[$label] RESULT: idmap probe FAILED on Lustre"
	echo "--- $cache_false ---"
	cat "$cache_false"; echo
	rm -rf "$graph" "$run"
	return 1
    fi
    echo "[$label] RESULT: probe did not run (no cache file written)"
    rm -rf "$graph" "$run"
    return 1
}

test_overlay_idmap_check()
{
    dmesg --console-level 8
    echo "Validating root is Lustre..."
    validate_lustre_mount /

    ensure_build

    run_probe "root" \
	"/ktest_cs_overlay_graph" "/ktest_cs_overlay_run" \
	"/tmp/cs-overlay.log"
}

main "$@"
