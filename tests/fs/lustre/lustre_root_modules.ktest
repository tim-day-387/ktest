#!/usr/bin/env bash
# SPDX-License-Identifier: GPL-2.0-only

#
# Run a simple boot test (client and server). The backing OSD is
# specified with FSTYPE. This variant builds LNET, Lustre, and ZFS
# as loadable modules (=m) rather than built-in.
#

. "$(dirname "$(readlink -e "${BASH_SOURCE[0]}")")/lustre-libs.sh"

config-kernel-base "$ktest_dir/config/debian-modules.config"
config-lustre-root

require-lustre-base-kernel-config
require-kernel-config IPV6=y
require-kernel-config VLAN_8021Q=y
require-lustre-builtin-kernel-config
require-kernel-config MODULES=y
require-kernel-config MODULE_UNLOAD

# USB boot requires these drivers built-in (no initramfs available)
require-kernel-config USB=y
require-kernel-config USB_XHCI_HCD=y
require-kernel-config USB_XHCI_PCI=y
require-kernel-config USB_EHCI_HCD=y
require-kernel-config USB_EHCI_PCI=y
require-kernel-config USB_STORAGE=y
require-kernel-config SCSI=y
require-kernel-config BLK_DEV_SD=y
require-kernel-config PINCTRL_METEORLAKE=y

config-mem 10G
config-timeout 60

# Promote any WARN() to a panic so the test fails loudly
require-kernel-append panic_on_warn=1

require-kernel-config DRM=y
require-kernel-config DRM_TTM=m
# Keep nouveau built as a module so it's bundled in the initramfs as a fallback
# stack, but blacklist it on the kernel cmdline below so it doesn't bind the GPU
# before the NVIDIA driver does. It can be modprobe'd by hand if NVIDIA fails.
require-kernel-config DRM_NOUVEAU=m

# Build NVIDIA open-gpu-kernel-modules against this kernel and bundle them into
# the initramfs so the GPU comes up under the proprietary stack at boot. The
# proprietary driver owns the GPU; nouveau is blacklisted so it can't bind first.
config-nvidia-modules
require-kernel-append nvidia-drm.modeset=1
require-kernel-append modprobe.blacklist=nouveau

config-uki-firmware

test_llmount()
{
    echo "Load Lustre..."
    modprobe lustre

    echo "Show mounts..."
    mount

    echo "Show space..."
    df -h

    echo "FIO!"
    cd ~
    fio --name=bulk_write_test \
	--size=100M \
	--bs=1M \
	--rw=write \
	--iodepth=32 \
	--numjobs=$(nproc) \
	--direct=1 \
	--time_based \
	--runtime=30 \
	--group_reporting
}

main "$@"
