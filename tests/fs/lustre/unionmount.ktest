#!/usr/bin/env bash
# SPDX-License-Identifier: GPL-2.0

#
# Run the unionmount-testsuite overlayfs regression tests on Lustre.
#
# https://github.com/amir73il/unionmount-testsuite
#

. "$(dirname "$(readlink -e "${BASH_SOURCE[0]}")")/lustre-libs.sh"

config-kernel-base "$ktest_dir/config/debian-modules.config"
config-lustre-root

require-lustre-base-kernel-config
require-kernel-config LNET=y
require-kernel-config LUSTRE=y
require-kernel-config ZFS=y
require-kernel-config MODULES=n

# USB boot requires these drivers built-in (no initramfs available)
require-kernel-config USB=y
require-kernel-config USB_XHCI_HCD=y
require-kernel-config USB_XHCI_PCI=y
require-kernel-config USB_EHCI_HCD=y
require-kernel-config USB_EHCI_PCI=y
require-kernel-config USB_STORAGE=y
require-kernel-config SCSI=y
require-kernel-config BLK_DEV_SD=y
require-kernel-config PINCTRL_METEORLAKE=y

require-kernel-config USER_NS
require-kernel-config OVERLAY_FS

config-networking tap
config-mem 10G
config-timeout 600

UNIONMOUNT_REPO="https://github.com/amir73il/unionmount-testsuite.git"
UNIONMOUNT_DIR="/ktest_unionmount"
UNIONMOUNT_BASE="/ktest_unionmount_base"

validate_lustre_mount()
{
    local mountpoint="$1"
    local fstype

    fstype=$(findmnt -n -o FSTYPE "$mountpoint")
    if [[ "$fstype" != "lustre" ]]; then
	echo "ERROR: $mountpoint is not Lustre (got '$fstype')"
	return 1
    fi
}

cleanup_unionmount()
{
    if [[ -d "$UNIONMOUNT_DIR" ]]; then
	(cd "$UNIONMOUNT_DIR" && ./run --clean-up) || true
    fi

    while findmnt "$UNIONMOUNT_BASE" >/dev/null 2>&1; do
	umount -R "$UNIONMOUNT_BASE" 2>/dev/null || break
    done

    rm -rf "$UNIONMOUNT_DIR" "$UNIONMOUNT_BASE"
}

test_unionmount_overlayfs()
{
    dmesg --console-level 8

    echo "Validating root is Lustre..."
    validate_lustre_mount /

    cleanup_unionmount

    git clone --depth 1 "$UNIONMOUNT_REPO" "$UNIONMOUNT_DIR"

    mkdir -p "$UNIONMOUNT_BASE"
    fstype=$(findmnt -n -o FSTYPE -T "$UNIONMOUNT_BASE")
    if [[ "$fstype" != "lustre" ]]; then
	echo "ERROR: $UNIONMOUNT_BASE not on Lustre (got '$fstype')"
	exit 1
    fi

    cd "$UNIONMOUNT_DIR"

    # --samefs places all overlay layers under UNIONMOUNT_BASEDIR, which we
    # point at a Lustre-backed directory so lower/upper/work all live on
    # Lustre.
    UNIONMOUNT_BASEDIR="$UNIONMOUNT_BASE" ./run --ov --samefs --verify

    cd /
    cleanup_unionmount
}

main "$@"
