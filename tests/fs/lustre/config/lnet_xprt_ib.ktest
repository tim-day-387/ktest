#!/usr/bin/env bash
# SPDX-License-Identifier: GPL-2.0

#
# LGTM coverage for CONFIG_LNET_XPRT_IB.
#

. "$(dirname "$(readlink -e "${BASH_SOURCE[0]}")")/lgtm.sh"

require-lgtm-kernel-config
require-kernel-config PCI=y
require-kernel-config INFINIBAND=m
require-kernel-config INFINIBAND_ADDR_TRANS=y
require-kernel-config LNET_XPRT_IB=m

main "$@"
