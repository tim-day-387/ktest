#!/usr/bin/env bash
# SPDX-License-Identifier: GPL-2.0

#
# LGTM coverage for CONFIG_LUSTRE_FS_GSS_KEYRING.
#

. "$(dirname "$(readlink -e "${BASH_SOURCE[0]}")")/lgtm.sh"

require-lgtm-kernel-config
require-kernel-config KEYS=y
require-kernel-config LUSTRE_FS_GSS=m
require-kernel-config LUSTRE_FS_GSS_KEYRING=y

main "$@"
