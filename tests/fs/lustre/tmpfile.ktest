#!/usr/bin/env bash
# SPDX-License-Identifier: GPL-2.0

#
# Run O_TMPFILE tests on Lustre (root filesystem).
#

. "$(dirname "$(readlink -e "${BASH_SOURCE[0]}")")/lustre-libs.sh"

require-lustre-kernel-config
require-lustre-debug-kernel-config
require-kernel-config LNET=y
require-kernel-config LUSTRE=y
require-kernel-config ZFS=y
require-kernel-config ROOT_LUSTRE=y
require-kernel-config USER_NS

config-mem 10G
config-timeout 60

validate_lustre_mount()
{
    local mountpoint="$1"
    local fstype

    fstype=$(findmnt -n -o FSTYPE "$mountpoint")
    if [[ "$fstype" != "lustre" ]]; then
	echo "ERROR: $mountpoint is not Lustre (got '$fstype')"
	return 1
    fi
}

# Basic: O_TMPFILE can be opened and closed
test_tmpfile()
{
    echo "Load Lustre (not really needed)..."
    modprobe lustre

    echo "Validating root is Lustre..."
    validate_lustre_mount /

    python3 - <<'EOF'
import os
import sys
try:
    fd = os.open(".", os.O_TMPFILE | os.O_RDWR)
    print("O_TMPFILE works")
    os.close(fd)
except OSError as e:
    print("O_TMPFILE failed:", e)
    sys.exit(1)
EOF
}

# Write data to a tmpfile and read it back
test_tmpfile_write_read()
{
    echo "Load Lustre (not really needed)..."
    modprobe lustre

    echo "Validating root is Lustre..."
    validate_lustre_mount /

    python3 - <<'EOF'
import os
import sys

data = b"Lustre O_TMPFILE write/read test\n" * 64

fd = os.open(".", os.O_TMPFILE | os.O_RDWR)

written = os.write(fd, data)
if written != len(data):
    print(f"ERROR: short write ({written} != {len(data)})")
    sys.exit(1)

os.lseek(fd, 0, os.SEEK_SET)
readback = os.read(fd, len(data))

if readback != data:
    print("ERROR: data mismatch after write/read")
    sys.exit(1)

# Verify file size via fstat
st = os.fstat(fd)
if st.st_size != len(data):
    print(f"ERROR: fstat size mismatch ({st.st_size} != {len(data)})")
    sys.exit(1)

os.close(fd)
print("write/read: OK")
EOF
}

# Multiple readers via /proc/self/fd see the same data
# and have independent file positions
test_tmpfile_multiple_readers()
{
    echo "Load Lustre (not really needed)..."
    modprobe lustre

    echo "Validating root is Lustre..."
    validate_lustre_mount /

    python3 - <<'EOF'
import os
import sys

NREADERS = 8
chunk = b"abcdefgh" * 512   # 4096 bytes per chunk
data = chunk * 16            # 64 KiB total

# Write known data via a writable tmpfile fd
wfd = os.open(".", os.O_TMPFILE | os.O_RDWR)
os.write(wfd, data)

# Open NREADERS independent read fds on the same inode
proc_path = f"/proc/self/fd/{wfd}"
rfds = [os.open(proc_path, os.O_RDONLY) for _ in range(NREADERS)]

# Each reader should see the full content independently
for i, rfd in enumerate(rfds):
    os.lseek(rfd, 0, os.SEEK_SET)
    readback = b""
    while len(readback) < len(data):
        chunk_read = os.read(rfd, 4096)
        if not chunk_read:
            break
        readback += chunk_read
    if readback != data:
        print(f"ERROR: reader {i} data mismatch")
        sys.exit(1)

# Verify file positions are independent: advance reader 0 halfway,
# then confirm reader 1 is still at its own position
half = len(data) // 2
os.lseek(rfds[0], 0, os.SEEK_SET)
os.read(rfds[0], half)
pos0 = os.lseek(rfds[0], 0, os.SEEK_CUR)

os.lseek(rfds[1], 0, os.SEEK_SET)
pos1 = os.lseek(rfds[1], 0, os.SEEK_CUR)

if pos0 != half:
    print(f"ERROR: reader 0 position unexpected ({pos0} != {half})")
    sys.exit(1)
if pos1 != 0:
    print(f"ERROR: reader 1 position contaminated by reader 0 ({pos1} != 0)")
    sys.exit(1)

for rfd in rfds:
    os.close(rfd)
os.close(wfd)
print(f"multiple readers ({NREADERS} fds, independent positions): OK")
EOF
}

# Concurrent readers via threads all see correct data
test_tmpfile_concurrent_readers()
{
    echo "Load Lustre (not really needed)..."
    modprobe lustre

    echo "Validating root is Lustre..."
    validate_lustre_mount /

    python3 - <<'EOF'
import os
import sys
import threading

NTHREADS = 16
data = bytes(range(256)) * 256   # 64 KiB, deterministic pattern

wfd = os.open(".", os.O_TMPFILE | os.O_RDWR)
os.write(wfd, data)

errors = []
barrier = threading.Barrier(NTHREADS)

def reader_thread(idx):
    try:
        rfd = os.open(f"/proc/self/fd/{wfd}", os.O_RDONLY)
        barrier.wait()   # all threads start reading at the same time
        os.lseek(rfd, 0, os.SEEK_SET)
        readback = b""
        while len(readback) < len(data):
            chunk = os.read(rfd, 4096)
            if not chunk:
                break
            readback += chunk
        if readback != data:
            errors.append(f"thread {idx}: data mismatch")
        os.close(rfd)
    except Exception as e:
        errors.append(f"thread {idx}: exception: {e}")

threads = [threading.Thread(target=reader_thread, args=(i,)) for i in range(NTHREADS)]
for t in threads:
    t.start()
for t in threads:
    t.join()

os.close(wfd)

if errors:
    for e in errors:
        print("ERROR:", e)
    sys.exit(1)

print(f"concurrent readers ({NTHREADS} threads): OK")
EOF
}

# Fork: child inherits tmpfile fd and reads data written by parent
test_tmpfile_fork_reader()
{
    echo "Load Lustre (not really needed)..."
    modprobe lustre

    echo "Validating root is Lustre..."
    validate_lustre_mount /

    python3 - <<'EOF'
import os
import sys

data = b"fork reader test data\n" * 256

fd = os.open(".", os.O_TMPFILE | os.O_RDWR)
os.write(fd, data)

pid = os.fork()
if pid == 0:
    # Child: open a fresh fd via /proc to get independent position
    try:
        rfd = os.open(f"/proc/self/fd/{fd}", os.O_RDONLY)
        os.lseek(rfd, 0, os.SEEK_SET)
        readback = b""
        while len(readback) < len(data):
            chunk = os.read(rfd, 4096)
            if not chunk:
                break
            readback += chunk
        if readback != data:
            os._exit(1)
        os.close(rfd)
        os._exit(0)
    except Exception:
        os._exit(2)
else:
    # Parent: also read independently
    os.lseek(fd, 0, os.SEEK_SET)
    readback = b""
    while len(readback) < len(data):
        chunk = os.read(fd, 4096)
        if not chunk:
            break
        readback += chunk

    _, status = os.waitpid(pid, 0)
    rc = os.waitstatus_to_exitcode(status)

    os.close(fd)

    if readback != data:
        print("ERROR: parent data mismatch")
        sys.exit(1)
    if rc != 0:
        print(f"ERROR: child exited with {rc}")
        sys.exit(1)

    print("fork reader: OK")
EOF
}

# linkat: promote tmpfile into the filesystem and read via path
test_tmpfile_linkat()
{
    echo "Load Lustre (not really needed)..."
    modprobe lustre

    echo "Validating root is Lustre..."
    validate_lustre_mount /

    python3 - <<'EOF'
import os
import sys
import ctypes
import ctypes.util

AT_EMPTY_PATH = 0x1000
AT_FDCWD = -100
# Target must be on the same Lustre filesystem as the tmpfile.
# /tmp is a separate tmpfs mount; use the Lustre root instead.
target = b"/ktest_tmpfile_linkat_test"

libc = ctypes.CDLL(ctypes.util.find_library("c"), use_errno=True)
libc.linkat.argtypes = [
    ctypes.c_int, ctypes.c_char_p,
    ctypes.c_int, ctypes.c_char_p,
    ctypes.c_int,
]
libc.linkat.restype = ctypes.c_int

data = b"linkat promotion test\n" * 128

fd = os.open(".", os.O_TMPFILE | os.O_RDWR)
os.write(fd, data)

# linkat(fd, "", AT_FDCWD, target, AT_EMPTY_PATH) promotes the tmpfile
ret = libc.linkat(fd, b"", AT_FDCWD, target, AT_EMPTY_PATH)
if ret != 0:
    err = ctypes.get_errno()
    print(f"ERROR: linkat failed: {os.strerror(err)}")
    sys.exit(1)

try:
    with open(target, "rb") as f:
        readback = f.read()
    if readback != data:
        print("ERROR: data mismatch after linkat promotion")
        sys.exit(1)

    st_fd   = os.fstat(fd)
    st_path = os.stat(target)
    if st_fd.st_ino != st_path.st_ino:
        print("ERROR: inode mismatch between fd and linked path")
        sys.exit(1)
finally:
    try:
        os.unlink(target)
    except OSError:
        pass

os.close(fd)
print("linkat promotion: OK")
EOF
}

# Large I/O: write and read back 64 MiB to stress the page cache path
test_tmpfile_large_io()
{
    echo "Load Lustre (not really needed)..."
    modprobe lustre

    echo "Validating root is Lustre..."
    validate_lustre_mount /

    python3 - <<'EOF'
import os
import sys
import hashlib

SIZE = 64 * 1024 * 1024   # 64 MiB
CHUNK = 1024 * 1024        # 1 MiB write/read chunks

fd = os.open(".", os.O_TMPFILE | os.O_RDWR)

h_write = hashlib.sha256()
written = 0
while written < SIZE:
    block = os.urandom(CHUNK)
    h_write.update(block)
    n = os.write(fd, block)
    if n != len(block):
        print(f"ERROR: short write at offset {written}")
        sys.exit(1)
    written += n

os.lseek(fd, 0, os.SEEK_SET)

h_read = hashlib.sha256()
read_total = 0
while read_total < SIZE:
    block = os.read(fd, CHUNK)
    if not block:
        print(f"ERROR: unexpected EOF at offset {read_total}")
        sys.exit(1)
    h_read.update(block)
    read_total += len(block)

os.close(fd)

if h_write.digest() != h_read.digest():
    print("ERROR: SHA-256 mismatch on large I/O")
    sys.exit(1)

print(f"large I/O ({SIZE // (1024*1024)} MiB): OK")
EOF
}

# Truncate: extend and shrink a tmpfile, verify size and zero-fill
test_tmpfile_truncate()
{
    echo "Load Lustre (not really needed)..."
    modprobe lustre

    echo "Validating root is Lustre..."
    validate_lustre_mount /

    python3 - <<'EOF'
import os
import sys

fd = os.open(".", os.O_TMPFILE | os.O_RDWR)

# Write 4 KiB of known data
data = b"\xAB" * 4096
os.write(fd, data)

# Extend to 1 MiB via ftruncate; new bytes must read as zero
os.ftruncate(fd, 1024 * 1024)
st = os.fstat(fd)
if st.st_size != 1024 * 1024:
    print(f"ERROR: size after extend = {st.st_size}")
    sys.exit(1)

os.lseek(fd, 4096, os.SEEK_SET)
hole = os.read(fd, 4096)
if hole != b"\x00" * 4096:
    print("ERROR: extended region not zero-filled")
    sys.exit(1)

# Shrink back to 2 KiB; data beyond should be gone
os.ftruncate(fd, 2048)
st = os.fstat(fd)
if st.st_size != 2048:
    print(f"ERROR: size after shrink = {st.st_size}")
    sys.exit(1)

os.lseek(fd, 0, os.SEEK_SET)
readback = os.read(fd, 4096)
if readback != data[:2048]:
    print("ERROR: data mismatch after shrink")
    sys.exit(1)

os.close(fd)
print("truncate (extend + shrink): OK")
EOF
}

# Open a tmpfile O_RDWR then reopen it O_RDONLY via /proc/self/fd;
# writes on the read-only fd must be refused with EBADF.
# Note: O_TMPFILE|O_RDONLY is rejected by the VFS (build_open_flags
# requires MAY_WRITE), so read-only access must go through /proc/self/fd.
test_tmpfile_rdonly()
{
    echo "Load Lustre (not really needed)..."
    modprobe lustre

    echo "Validating root is Lustre..."
    validate_lustre_mount /

    python3 - <<'EOF'
import os
import sys
import errno

wfd = os.open(".", os.O_TMPFILE | os.O_RDWR)
os.write(wfd, b"hello")

rfd = os.open(f"/proc/self/fd/{wfd}", os.O_RDONLY)

try:
    os.write(rfd, b"should fail")
    print("ERROR: write to O_RDONLY fd should have failed")
    os.close(rfd)
    os.close(wfd)
    sys.exit(1)
except OSError as e:
    if e.errno != errno.EBADF:
        print(f"ERROR: unexpected errno {e.errno} ({e})")
        os.close(rfd)
        os.close(wfd)
        sys.exit(1)

os.close(rfd)
os.close(wfd)
print("O_RDONLY write rejection: OK")
EOF
}

main "$@"
