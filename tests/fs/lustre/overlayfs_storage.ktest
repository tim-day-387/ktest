#!/usr/bin/env bash
# SPDX-License-Identifier: GPL-2.0

#
# Build containers/storage outside of overlayfs and exercise its overlay
# graph driver against /tmp.
#

. "$(dirname "$(readlink -e "${BASH_SOURCE[0]}")")/lustre-libs.sh"

config-kernel-base "$ktest_dir/config/debian-modules.config"
config-lustre-root

require-lustre-base-kernel-config
require-lustre-builtin-kernel-config
require-kernel-config MODULES=y

require-kernel-config USER_NS
require-kernel-config OVERLAY_FS

config-networking tap
config-mem 10G
config-timeout 120

BUILD_DIR="/ktest_cstorage"
GRAPH_ROOT="/tmp/cs-overlay-test"
RUN_ROOT="/tmp/cs-overlay-run"
PODMAN_ROOT="/tmp/podman-overlay-test"
PODMAN_RUN_ROOT="/tmp/podman-overlay-run"

validate_lustre_mount()
{
    local mountpoint="$1"
    local fstype

    fstype=$(findmnt -n -o FSTYPE "$mountpoint")
    if [[ "$fstype" != "lustre" ]]; then
	echo "ERROR: $mountpoint is not Lustre (got '$fstype')"
	return 1
    fi
}

test_containers_storage_overlay()
{
    dmesg --console-level 8

    echo "Validating root is Lustre..."
    validate_lustre_mount /

    if ! command -v go &>/dev/null || ! command -v podman &>/dev/null; then
	echo "Installing dependencies..."
	apt-get update
	apt-get install -y golang-go podman
    fi

    rm -rf "$BUILD_DIR" "$GRAPH_ROOT" "$RUN_ROOT" "$PODMAN_ROOT" "$PODMAN_RUN_ROOT"
    mkdir -p "$BUILD_DIR"

    export GOCACHE="$BUILD_DIR/gocache"
    export GOPATH="$BUILD_DIR/gopath"

    cd "$BUILD_DIR"
    git clone --depth 1 https://github.com/containers/storage.git
    cd storage

    fstype=$(findmnt -n -o FSTYPE -T .)
    if [[ "$fstype" == "overlay" ]]; then
	echo "ERROR: build dir is overlayfs (got '$fstype'), expected non-overlay"
	exit 1
    fi

    go build -tags exclude_graphdriver_btrfs ./cmd/containers-storage

    ./containers-storage -D -g "$GRAPH_ROOT" -R "$RUN_ROOT" status

    echo "Running alpine container with native overlay driver..."
    podman --root "$PODMAN_ROOT" --runroot "$PODMAN_RUN_ROOT" \
	--cgroup-manager=cgroupfs \
	--events-backend=file \
	--storage-driver overlay \
	--storage-opt overlay.mount_program= \
	run --rm docker.io/library/alpine sleep 1

    cd /
    rm -rf "$BUILD_DIR" "$GRAPH_ROOT" "$RUN_ROOT" "$PODMAN_ROOT" "$PODMAN_RUN_ROOT"
}

main "$@"
