#
# Run a simple boot test (client and server). The backing OSD is
# specified with FSTYPE.
#
# Author: Timothy Day <timday@amazon.com>
#

. "$(dirname "$(readlink -e "${BASH_SOURCE[0]}")")/lustre-libs.sh"

require-lustre-kernel-config
require-lustre-debug-kernel-config
require-kernel-config LIBCFS=m
require-kernel-config LNET=m
require-kernel-config LUSTRE=m
require-kernel-config ZFS=m

config-mem 10G
config-timeout 120

test_llmount()
{
    modprobe lustre
    modprobe zfs
    modprobe osd-zfs

    setup_lustrefs

    sleep 10

    cd /mnt/lustre
    fio --name=bulk_write_test \
	--size=10M \
	--bs=1M \
	--rw=write \
	--iodepth=32 \
	--numjobs=$(nproc) \
	--direct=1 \
	--time_based \
	--runtime=30 \
	--group_reporting
    cd -

    # Dump memory allocation profiling (CONFIG_MEM_ALLOC_PROFILING),
    # sorted by bytes allocated, to attribute memory use to callsites.
    echo "=== MEM_ALLOC_PROFILING (/proc/allocinfo) ==="
    # head closing the pipe early sends SIGPIPE to sort (exit 141); tolerate it
    # so pipefail/set -e don't fail the test.
    sort -grk1 /proc/allocinfo | head -50 || true

    cleanup_lustrefs

    "$LUSTRE_RMMOD" zfs
    "$LUSTRE_RMMOD"
    lsmod
}

main "$@"
