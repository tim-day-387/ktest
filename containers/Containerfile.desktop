# SPDX-License-Identifier: GPL-2.0-only

ARG ROOT_BASE=localhost/ktest-root-base:latest
FROM ${ROOT_BASE}

# Un-minimize the packages inherited from the ubuntu:24.04 container base.
# Containerfile.root_image drops dpkg's doc-stripping excludes before
# installing anything, so only the base image's own packages are missing
# their man pages/docs; it records their names in base-packages.list.
# Reinstall exactly those, rather than running Ubuntu's unminimize script:
# its blanket reinstall of everything owning /usr/share/man includes the
# locally-installed Lustre debs, which apt cannot re-download.  Then drop
# the "this system has been minimized" login banner.
RUN apt-get update \
 && xargs -a /usr/share/ktest/base-packages.list -r \
        apt-get install --reinstall -y \
 && rm -f /etc/update-motd.d/60-unminimize \
 && rm -rf /var/lib/apt/lists/*

# Passwordless sudo for the sudo group
RUN echo '%sudo ALL=(ALL:ALL) NOPASSWD:ALL' > /etc/sudoers.d/90-nopasswd \
 && chmod 0440 /etc/sudoers.d/90-nopasswd

# Hostname.
RUN echo ktest-lustre > /etc/hostname

# The single human user
ARG DESKTOP_USER=timothy
ARG DESKTOP_UID=1000

# Ubuntu 24.04's base image ships a default 'ubuntu' user at uid 1000; drop
# whoever holds the target uid before creating our user.
RUN if existing=$(getent passwd ${DESKTOP_UID} | cut -d: -f1) && [ -n "$existing" ]; then \
        userdel -r "$existing" 2>/dev/null || userdel "$existing"; \
    fi \
 && useradd -m -u ${DESKTOP_UID} -s /bin/bash \
        -G sudo,adm,cdrom,dip,plugdev,lpadmin ${DESKTOP_USER} \
 && passwd -d ${DESKTOP_USER}

# Tim's bashrc for the interactive user.
COPY --chown=${DESKTOP_UID}:${DESKTOP_UID} tools/timbashrc /home/${DESKTOP_USER}/.bashrc

# The NVIDIA userland (libGL/EGL/Vulkan, the X driver, nvidia-smi, the
# nvidia-modprobe setuid helper).  Only userspace: the matching kernel modules
# come from the open-gpu-kernel-modules build in qlkbuild (build_nvidia), so
# --no-kernel-module skips the in-installer build and DKMS registration.
# Keep this version in lockstep with the open-gpu-kernel-modules tag in
# Containerfile.ktest.u26.
#
# --no-kernel-module also skips the GSP firmware, which the installer treats as
# part of the kernel-module component -- so install it by hand.  nvidia.ko is
# loaded by udev after init switch_root's into this image, and the firmware
# loader only searches /lib/firmware on the *new* root; the copy mk_initramfs
# bundles into the initramfs is out of reach by then (init bind-mounts
# /lib/modules across the switch, but not /lib/firmware).  Extract once and
# reuse the tree for both halves so this is a single download.
ARG NVIDIA_DRIVER_VERSION=610.43.02
RUN cd /tmp \
 && run=NVIDIA-Linux-x86_64-${NVIDIA_DRIVER_VERSION}.run \
 && curl -fsSL -O "https://us.download.nvidia.com/XFree86/Linux-x86_64/${NVIDIA_DRIVER_VERSION}/$run" \
 && sh "$run" --extract-only --target nvidia-run \
 && (cd nvidia-run && ./nvidia-installer --silent --no-kernel-module --install-libglvnd) \
 && install -d /lib/firmware/nvidia/${NVIDIA_DRIVER_VERSION} \
 && install -m 0644 nvidia-run/firmware/*.bin \
        /lib/firmware/nvidia/${NVIDIA_DRIVER_VERSION}/ \
 && rm -rf nvidia-run "$run"

# Boot to the graphical target. Done as a direct symlink rather than
# `systemctl set-default` so it works offline / cross-arch.
RUN ln -sf /lib/systemd/system/graphical.target \
        /etc/systemd/system/default.target
