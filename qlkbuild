set -o nounset
set -o errexit
set -o errtrace

ktest_dir=$(dirname "$(readlink -f "$0")")

. "$ktest_dir/lib/libktest.sh"

checkdep clang
checkdep bison
checkdep bear
checkdep flex
checkdep make
checkdep gcc
checkdep bc

# Lustre parameters
export CC="${CC:-clang-23}"
export FSTYPE="${BACKING_STORAGE:-wbcfs}"

# Ktest parameters
ktest_kernel_source="$(realpath -e ~/git/linux/ 2>/dev/null || true)"
ktest_lustre_source="$ktest_kernel_source/../lustre-release/"
ktest_zfs_source="$ktest_kernel_source/../zfs/"
ktest_nvidia_source="$ktest_kernel_source/../open-gpu-kernel-modules/"
ktest_llvm_source="$ktest_kernel_source/../llvm-project/"
ktest_boot_test="$ktest_dir/tests/fs/lustre/boot.ktest"
ktest_ccplugin="$ktest_dir/cplugin/build/xunused"
ktest_compiler="${CC:-clang-23}"
ktest_skip_kernel_config=false
ktest_lustre_allow_warnings=0
ktest_lustre_build_enable=1
ktest_kernel_build_enable=1
# Set to 1 by a test's config-nvidia-modules (emitted from its deps phase and
# eval'd via parse_test_deps); gates build_nvidia/install of the NVIDIA modules.
ktest_nvidia=0
ktest_out="/tmp/ktest-out/"
ktest_lustre_clean_git=0
ktest_lustre_purge=0
ktest_njobs=$(nproc)
ktest_precise=false
ktest_loop=false
DEPMOD=depmod
MAKEARGS=()
COVERAGE=""

if ! which depmod > /dev/null; then
    DEPMOD=/sbin/depmod
fi

# Compute kernel LOCALVERSION with lustre/zfs commits and date
function compute_localversion()
{
    local lustre_commit=""
    local zfs_commit=""
    local date_str=$(date +%Y%m%d)

    # Get Lustre commit (short hash)
    if [[ -d "$ktest_lustre_source/.git" ]]; then
        lustre_commit=$(git -C "$ktest_lustre_source" rev-parse --short=7 HEAD 2>/dev/null || echo "")
    fi

    # Get ZFS commit (short hash)
    if [[ -d "$ktest_zfs_source/.git" ]]; then
        zfs_commit=$(git -C "$ktest_zfs_source" rev-parse --short=7 HEAD 2>/dev/null || echo "")
    fi

    # Build version string: -ktest-<lustre>-<zfs>-<date>
    if [[ -n "$lustre_commit" ]] && [[ -n "$zfs_commit" ]]; then
        echo "-ktest-${lustre_commit}-${zfs_commit}-${date_str}"
    elif [[ -n "$lustre_commit" ]]; then
        echo "-ktest-${lustre_commit}-${date_str}"
    else
        echo "-ktest"
    fi
}

export KTEST_LOCALVERSION=$(compute_localversion)

function usage()
{
    echo "qlkbuild: Quick Lustre Kernel Build"
    echo "Usage: qlkbuild cmd [options]"
    ktest_usage_cmds
    echo "  build <test>        Build kernel for a test configuration"
    echo "  ccplugin <test>     Build and run CC plugin"
    echo "  oldconfig           Run make oldconfig"
    echo "  config              Run make nconfig"
    echo
    ktest_usage_post
}

if [[ $# = 0 ]]; then
    usage
    exit 1
fi

# Parse command
CMD="$1"
shift

# The native platform builds Lustre in-tree (into the kernel/module tree),
# while mainline builds it out-of-tree from lustre-release. Export a flag so a
# test's deps phase (run as a subprocess of this script) can request the
# matching Lustre kernel config, e.g. llmount.ktest pulling in the in-kernel
# modules on native.
case "$CMD" in
    build_native|run_native|package_native|generate_lustre_patch)
	export ktest_lustre_intree=1
	;;
    *)
	export ktest_lustre_intree=0
	;;
esac

while getopts "h${ktest_args}" arg; do
    case $arg in
	h)
	    usage
	    exit 0
	    ;;
    esac
    parse_ktest_arg $arg
done
shift $(( OPTIND - 1 ))

parse_args_post

# default parameters
[[ -z $ktest_kernel_source ]]	&& ktest_kernel_source="."

if [[ ! -d $ktest_kernel_source ]]; then
    echo "kernel source directory $ktest_kernel_source does not exist"
    exit 1
fi

ktest_kernel_source=$(readlink -e "$ktest_kernel_source")

ktest_kernel_build="$ktest_out/kernel_build.$ktest_arch"
ktest_lustre_build="$ktest_out/lustre-release"
ktest_zfs_build="$ktest_out/zfs"
ktest_nvidia_build="$ktest_out/open-gpu-kernel-modules"
# Deliberately outside $ktest_out: several paths (purge_previous_results,
# cmd_build's final strip-to-UKI) wipe $ktest_out mid-flow, and the toolchain
# must survive them.  /tmp is per-container, so no cross-run staleness.
# No dashes in this path: lustre's LTC_LLVM_TOOLCHAIN on older branches
# treats any LLVM value containing '-' as a version suffix, so a dashed
# prefix path would be appended to the tool names as well.
ktest_llvm_build="/tmp/ktest_llvm"
mkdir -p "$ktest_kernel_build"
mkdir -p "$ktest_lustre_build"
if [[ -d "$ktest_zfs_source" ]]; then
    mkdir -p "$ktest_zfs_build"
fi
if [[ -d "$ktest_nvidia_source" ]]; then
    mkdir -p "$ktest_nvidia_build"
fi

if [[ -n $CROSS_COMPILE ]]; then
    checkdep "$ARCH_TRIPLE-gcc" "gcc-$ARCH_TRIPLE"
fi

function check_file() {
    local file="$1"

    if [[ ! -f "$file" ]]; then
	echo "$file not found!"
	exit 1
    fi

    return 0
}

function validate_lustre_build() {
    check_file "$ktest_lustre_build/lnet/lnet/lnet.ko"
    check_file "$ktest_lustre_build/lustre/llite/lustre.ko"

    # Check OSD module based on FSTYPE (backing storage)
    if [[ "$FSTYPE" == "zfs" ]]; then
	check_file "$ktest_lustre_build/lustre/osd-zfs/osd_zfs.ko"
    else
	check_file "$ktest_lustre_build/lustre/osd-wbcfs/osd_wbcfs.ko"
    fi
}

function validate_native_lustre_build() {
    check_file "$ktest_kernel_build/net/lnet/lnet/lnet.ko"
    check_file "$ktest_kernel_build/fs/lustre/llite/lustre.ko"

    # Check OSD module based on FSTYPE (backing storage)
    if [[ "$FSTYPE" == "zfs" ]]; then
	check_file "$ktest_kernel_build/fs/lustre/osd-zfs/osd_zfs.ko"
    else
	check_file "$ktest_kernel_build/fs/lustre/osd-wbcfs/osd_wbcfs.ko"
    fi
}

function cmd_run()
{
    if [[ $# = 0 ]]; then
	ktest_test="$ktest_boot_test"
    else
	ktest_test=$(realpath "$1")
	shift
    fi

    ktest_testargs="$@"
    parse_test_deps "$ktest_test"

    start_vm
}

function generate_coverage()
{
    local coverage_output="/tmp/ktest-output"

    # Nothing to do if no gcov data was collected
    compgen -G "$ktest_out/gcov.*" > /dev/null 2>&1 || return 0

    # The .gcno files reference source paths under the kernel tree populated
    # by copy-builtin.  Apply the patch so lcov can find those files.
    if [[ -f "$ktest_out/lustre.patch" && ! -d "$ktest_kernel_source/fs/lustre" ]]; then
	git -C "$ktest_kernel_source" am "$ktest_out/lustre.patch"
    fi

    "$ktest_dir/coveragetool" -o "$ktest_out"

    if [[ -d $coverage_output && -d $ktest_out/lcov ]]; then
        cp -r "$ktest_out/lcov" "$coverage_output/coverage"
    fi
}

function cmd_run_native()
{
    if [[ $# = 0 ]]; then
	ktest_test="$ktest_dir/tests/fs/lustre/inkernel.ktest"
    else
	ktest_test=$(realpath "$1")
	shift
    fi

    ktest_testargs="$@"
    parse_test_deps "$ktest_test"

    if [[ -n $COVERAGE ]]; then
	ktest_kernel_config_require+=(GCOV_KERNEL)
    fi

    start_vm
    generate_coverage
}

function build_lustre_intree()
{
    local old="$PWD"
    local LINUX_OBJ="/tmp/ktest-out/kernel_build.x86_64/"
    local SUBARCH="x86"

    cd "$ktest_lustre_build"

    rsync --archive -r "$ktest_lustre_source" "$ktest_lustre_build"
    apply_lustre_patches

    # No strict errors
    if [[ "${ktest_lustre_allow_warnings}" == "1" ]]; then
	export CFLAGS="-Wno-error=attribute-warning -Wno-error=unused-but-set-variable -Wno-error=single-bit-bitfield-constant-conversion -Wno-error=format-security -Wno-error=cast-function-type-strict"
    else
	export CFLAGS="-Werror"
    fi

    # Find headers
    export CFLAGS="$CFLAGS -I$LINUX_OBJ/include"
    export CFLAGS="$CFLAGS -I$LINUX_OBJ/include"
    export CFLAGS="$CFLAGS -I$LINUX_OBJ/arch/$SUBARCH/include/generated"
    export CFLAGS="$CFLAGS -I$LINUX_OBJ/arch/$SUBARCH/include/generated/uapi"
    export CFLAGS="$CFLAGS -I$LINUX_OBJ/include/generated"
    export CFLAGS="$CFLAGS -I$LINUX_OBJ/include/generated/uapi"
    export KCFLAGS="-I$LINUX_OBJ/include"
    export KCFLAGS="$KCFLAGS -I$LINUX_OBJ/arch/$SUBARCH/include/generated"
    export KCFLAGS="$KCFLAGS -I$LINUX_OBJ/arch/$SUBARCH/include/generated/uapi"
    export KCFLAGS="$KCFLAGS -I$LINUX_OBJ/include/generated"
    export KCFLAGS="$KCFLAGS -I$LINUX_OBJ/include/generated/uapi"

    # Configure OSD based on FSTYPE (backing storage)
    if [[ "$FSTYPE" == "zfs" ]]; then
	export with_ldiskfs="no"
	export with_zfs="$ktest_zfs_build"
	export with_zfs_obj="$ktest_zfs_build"
	export with_spl="$ktest_zfs_build"
	export with_spl_obj="$ktest_zfs_build"
    else
	export with_ldiskfs="no"
	export with_zfs="no"
    fi

    # Disable optional features
    export with_o2ib="no"
    export enable_gss="no"
    export enable_crypto="no"

    # Always build the server
    export enable_server="yes"

    # ktest uses statically linked tools
    export enable_shared="no"

    # Assume that Linux is in the same directory as Lustre
    export with_linux="$ktest_kernel_source"

    # Build the kernel via ktest into tmp
    export ARCH="$(uname -m)"
    export with_linux_obj="/tmp/ktest-out/kernel_build.$ARCH/"

    # Misc
    export LLVM="$(map_clang_version)"

    ./autogen.sh
    ./configure || { cat config.log; exit 1; }

    validate_lustre_intree_build

    cd "$old"
}

function validate_lustre_intree_build() {
    check_file "$ktest_lustre_build/config.h"
}

