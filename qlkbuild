    export CFLAGS="$CFLAGS -I$LINUX_OBJ/arch/$SUBARCH/include/generated/uapi"
    export CFLAGS="$CFLAGS -I$LINUX_OBJ/include/generated"
    export CFLAGS="$CFLAGS -I$LINUX_OBJ/include/generated/uapi"
    export KCFLAGS="-I$LINUX_OBJ/include"
    export KCFLAGS="$KCFLAGS -I$LINUX_OBJ/arch/$SUBARCH/include/generated"
    export KCFLAGS="$KCFLAGS -I$LINUX_OBJ/arch/$SUBARCH/include/generated/uapi"
    export KCFLAGS="$KCFLAGS -I$LINUX_OBJ/include/generated"
    export KCFLAGS="$KCFLAGS -I$LINUX_OBJ/include/generated/uapi"

    # Configure OSD based on FSTYPE (backing storage)
    if [[ "$FSTYPE" == "zfs" ]]; then
	export with_ldiskfs="no"
	export with_zfs="$ktest_zfs_build"
	export with_zfs_obj="$ktest_zfs_build"
	export with_spl="$ktest_zfs_build"
	export with_spl_obj="$ktest_zfs_build"
    else
	export with_ldiskfs="no"
	export with_zfs="no"
    fi

    # Disable optional features
    export with_o2ib="no"
    export enable_gss="no"
    export enable_crypto="no"

    # Always build the server
    export enable_server="yes"

    # ktest uses statically linked tools
    export enable_shared="no"

    # Assume that Linux is in the same directory as Lustre
    export with_linux="$ktest_kernel_source"

    # Build the kernel via ktest into tmp
    export ARCH="$(uname -m)"
    export with_linux_obj="/tmp/ktest-out/kernel_build.$ARCH/"

    # Misc
    export LLVM="$(map_clang_version)"

    ./autogen.sh
    ./configure || cat config.log
    bear -- make -j$ktest_njobs

    # Newer kernels have these lines that the plugin hates
    sed -i '/-Wp,-MMD,.*\.d/d' "$ktest_lustre_build/compile_commands.json"

    validate_lustre_build

    cd "$old"
}

function apply_patches() {
    local patches_dir="$1"
    local target_repo="$2"

    [[ -d "$patches_dir" ]] || return 0

    shopt -s nullglob
    local patches=("$patches_dir"/*.patch)
    shopt -u nullglob

    [[ ${#patches[@]} -gt 0 ]] || return 0

    for patch in "${patches[@]}"; do
	local name=$(basename "$patch")
	if git -C "$target_repo" apply --whitespace=nowarn "$patch"; then
	    echo "Applied patch: $name"
	else
	    echo "WARNING: Failed to apply patch $name (continuing)"
	fi
    done
}

function apply_lustre_patches() {
    apply_patches "$ktest_dir/patches/lustre" "$ktest_lustre_build"
}

function apply_linux_patches() {
    apply_patches "$ktest_dir/patches/linux" "$ktest_kernel_source"
}

function purge_build_junk() {
    local dir="$1"

    [[ -d "$dir" ]] || return 0

    # Intermediate build artifacts the runtime/initramfs doesn't need.
    # Drops object files, libtool intermediates, kbuild dep records.
    # Keeps .ko/.so/.la/binaries/scripts.
    find "$dir" \( \
	-name '*.o' -o \
	-name '*.lo' -o \
	-name '*.cmd' -o \
	-name '*.mod' -o \
	-name '*.mod.c' -o \
	-name '*.d' \
    \) -type f -delete 2>/dev/null || true
}

function safe_delete_dir() {
    local dir="$1"

    # Check that an argument was provided
    if [ -z "$dir" ]; then
        echo "Error: no directory provided" >&2
        return 1
    fi

    # Check that it exists and is a directory
    if [ ! -d "$dir" ]; then
        echo "Warning: '$dir' does not exist or is not a directory" >&2
        return 0
    fi

    # Safety check: only allow deletion inside /tmp
    case "$dir" in
        /tmp/*)
            if [ "$dir" = "/tmp" ]; then
                echo "Refusing to delete /tmp itself" >&2
                return 1
            fi
            echo "Deleting directory: $dir"
            rm -rf -- "$dir"
            ;;
        *)
            echo "Refusing to delete: '$dir' (not under /tmp)" >&2
            return 1
            ;;
    esac
}

function purge_previous_results()
{
    run_quiet_with_status "CLEANUP" "DONE" safe_delete_dir "$ktest_out"
    mkdir -p "$ktest_kernel_build"
    mkdir -p "$ktest_lustre_build"
    if [[ -d "$ktest_zfs_source" ]]; then
	mkdir -p "$ktest_zfs_build"
    fi
}

function run_copy_builtin()
{
    local old="$PWD"
    local patch_output_dir="/tmp/ktest-output"

    mkdir -p "$patch_output_dir"

    cd "$ktest_kernel_source"

    # Apply ZFS patch if it exists (must be applied before Lustre)
    if [[ -f "$ktest_out/zfs.patch" ]]; then
	echo "Applying ZFS patch..."
	git am "$ktest_out/zfs.patch"
    fi

    cd "$ktest_lustre_build"

    # If a build step hasn't already staged the Lustre source here (the
    # cached-config.h path skips the full configure), stage it now so
    # copy-builtin and the Lustre tree are present. copy-builtin itself
    # reuses the cached config.h from the kernel tree when one exists.
    if [[ ! -x ./copy-builtin ]]; then
	rsync --archive -r "$ktest_lustre_source" "$ktest_lustre_build"
	apply_lustre_patches
    fi

    # copy-builtin drops the osd-zfs tree unless CBI_WITH_ZFS is set. On a ZFS
    # build the ZFS patch has already been applied above, so opt in and let
    # copy-builtin wire up the osd-zfs Kconfig and in-tree header paths.
    if [[ "$FSTYPE" == "zfs" ]]; then
	export CBI_WITH_ZFS=1
    fi

    ./copy-builtin "$ktest_kernel_source"
    cd "$ktest_kernel_source"
    git add *
    git add -f lustre_config.h
    if [[ -d include/lustre_compat ]]; then
	git add include/lustre_compat
    fi
    git commit -m "Lustre"

    # Save patches to /tmp before purging
    git format-patch HEAD~1 --stdout > /tmp/lustre.patch
    if [[ -f "$ktest_out/zfs.patch" ]]; then
	cp "$ktest_out/zfs.patch" /tmp/zfs.patch
    fi

    purge_previous_results

    # Restore patches after purge
    mv /tmp/lustre.patch "$ktest_out/lustre.patch"
    if [[ -f /tmp/zfs.patch ]]; then
	mv /tmp/zfs.patch "$ktest_out/zfs.patch"
    fi

    # Copy patches to output directory
    cp "$ktest_out/lustre.patch" "$patch_output_dir/"
    if [[ -f "$ktest_out/zfs.patch" ]]; then
	cp "$ktest_out/zfs.patch" "$patch_output_dir/"
    fi

    cd "$old"
}

function build_zfs_full()
{
    local old="$PWD"
    local LINUX_OBJ="/tmp/ktest-out/kernel_build.x86_64/"

    cd "$ktest_zfs_build"
    rsync --archive -r "$ktest_zfs_source" "$ktest_zfs_build"
    sed -i 's/CDDL/GPL/' "$ktest_zfs_build/META"

    # Configure ZFS - build modules first to generate Module.symvers
    export ARCH="$(uname -m)"
    export LLVM="$(map_clang_version)"

    ./autogen.sh
    ./configure \
        --with-linux="$ktest_kernel_source" \
        --with-linux-obj="$LINUX_OBJ" \
        --enable-linux-experimental

    # Build ZFS modules to generate headers and Module.symvers.
    #
    # KASAN kernels: clang treats -fsanitize=kernel-address as the
    # address_sanitizer feature, so ZFS's bundled ZSTD (which keys off
    # __has_feature(address_sanitizer)) activates its workspace-poisoning
    # path and emits __asan_{,un}poison_memory_region calls. The kernel does
    # not export those to modules, so modpost fails with them undefined. The
    # in-kernel zstd suppresses the same path via ZSTD_ASAN_DONT_POISON_WORKSPACE;
    # do the same here. Command-line make vars propagate to the kernel sub-make
    # via MAKEFLAGS, so this reaches the module compile. No-op off KASAN.
    make -j$ktest_njobs KCFLAGS=-DZSTD_ASAN_DONT_POISON_WORKSPACE

    validate_zfs_build

    cd "$old"
}

function validate_nvidia_build() {
    check_file "$ktest_nvidia_build/kernel-open/nvidia.ko"
    check_file "$ktest_nvidia_build/kernel-open/nvidia-drm.ko"
    check_file "$ktest_nvidia_build/kernel-open/nvidia-modeset.ko"
}

# Build the NVIDIA open-gpu-kernel-modules out-of-tree against the kernel under
# test.  Mirrors build_zfs_full: rsync the sibling checkout into the build dir,
# then build with the same compiler/arch the kernel used.  SYSSRC/SYSOUT point
# the NVIDIA Kbuild at our out-of-tree kernel build (source + O= obj dir), the
# same split as ZFS's --with-linux/--with-linux-obj.  Output .ko land in
# kernel-open/; install_fs_modules copies them into the initramfs module tree.
function build_nvidia()
{
    local old="$PWD"

    if [[ ! -d "$ktest_nvidia_source" ]]; then
	echo "NVIDIA source not found at $ktest_nvidia_source"
	echo "Clone github.com/NVIDIA/open-gpu-kernel-modules there (pinned to"
	echo "the release matching the host driver) to build the NVIDIA modules."
	exit 1
    fi

    # Create our own build dir rather than relying on the startup mkdir, which is
    # gated on the source dir and skipped on build paths (e.g. package_native)
    # that don't otherwise touch it.
    mkdir -p "$ktest_nvidia_build"
    cd "$ktest_nvidia_build"
    rsync --archive -r "$ktest_nvidia_source" "$ktest_nvidia_build"

    export ARCH="$(uname -m)"
    export LLVM="$(map_clang_version)"

    make -j$ktest_njobs modules			\
	SYSSRC="$ktest_kernel_source"		\
	SYSOUT="$ktest_kernel_build"		\
	CC="$ktest_compiler"

    validate_nvidia_build

    cd "$old"
}

# Build the NVIDIA modules and install them into the kernel module tree when the
# test opted in via config-nvidia-modules (ktest_nvidia=1, threaded through the
# deps phase).  Shared by every UKI-producing path (cmd_build_native /
# cmd_package_native) so the driver gets bundled consistently; cmd_build wires
# the same steps inline because it already runs install_fs_modules for lustre/zfs.
function maybe_build_nvidia()
{
    [[ "$ktest_nvidia" == "1" ]] || return 0

    run_quiet_with_status "NVIDIA BUILD [$(basename "$ktest_test")]" "DONE" build_nvidia
    purge_build_junk "$ktest_nvidia_build"
    run_quiet_with_status "INSTALL FS MODULES [$(basename "$ktest_test")]" "DONE" install_fs_modules
}

# Build a custom LLVM/Clang toolchain from an llvm-project checkout sitting as
# a sibling of the kernel tree (podman-ktest overlay-mounts ktest_llvm_source
# there).  Only the tools kbuild's LLVM=1 mode actually invokes are built, not
# the default all target.  Compiles route through ccache (LLVM_CCACHE_BUILD)
# against the persistent /tmp/ccache mount, so rebuilding an unchanged
# checkout in a fresh container is mostly link time.
function build_llvm()
{
    local cmake_args=()
    local extra_args=()
    local lld

    # Bootstrap with the packaged clang when available.  Name it by full path:
    # /usr/local/bin/clang-23 is a ccache symlink, and LLVM_CCACHE_BUILD
    # already provides the launcher, so avoid wrapping ccache twice.
    if [[ -x /usr/bin/clang-23 ]]; then
	cmake_args+=(-DCMAKE_C_COMPILER=/usr/bin/clang-23)
	cmake_args+=(-DCMAKE_CXX_COMPILER=/usr/bin/clang++-23)
    fi

    # lld keeps link memory/time manageable next to bfd
    for lld in ld.lld-23 ld.lld; do
	if command -v "$lld" > /dev/null; then
	    cmake_args+=("-DLLVM_USE_LINKER=$(command -v "$lld")")
	    break
	fi
    done

    # Extra CMake options forwarded from the environment, e.g.
    # KTEST_LLVM_CMAKE_ARGS="-DLLVM_ENABLE_ASSERTIONS=OFF"
    if [[ -n "${KTEST_LLVM_CMAKE_ARGS:-}" ]]; then
	read -ra extra_args <<< "$KTEST_LLVM_CMAKE_ARGS"
    fi

    cmake -G Ninja					\
	-S "$ktest_llvm_source/llvm"			\
	-B "$ktest_llvm_build"				\
	-DCMAKE_BUILD_TYPE=Release			\
	-DLLVM_ENABLE_PROJECTS="clang;lld"		\
	-DLLVM_TARGETS_TO_BUILD="X86;AArch64"		\
	-DLLVM_ENABLE_ASSERTIONS=ON			\
	-DLLVM_CCACHE_BUILD=ON				\
	-DLLVM_ENABLE_BINDINGS=OFF			\
	"${cmake_args[@]}"				\
	"${extra_args[@]}"

    # Everything kbuild's LLVM=<bin>/ prefix mode invokes: CC/LD plus the
    # llvm binutils substituted for AR/NM/OBJCOPY/OBJDUMP/READELF/STRIP.
    ninja -C "$ktest_llvm_build" -j"$ktest_njobs"	\
	clang lld llvm-ar llvm-nm llvm-objcopy		\
	llvm-objdump llvm-readelf llvm-strip llvm-size

    check_file "$ktest_llvm_build/bin/clang"
    check_file "$ktest_llvm_build/bin/ld.lld"
}

# Build and adopt the custom toolchain when an LLVM source tree is present.
# The mount point exists (empty) in every container, so key off the tree's
# content; without a mount this is a no-op and the packaged clang is used.
function maybe_build_llvm()
{
    [[ -f "$ktest_llvm_source/llvm/CMakeLists.txt" ]] || return 0

    checkdep cmake
    checkdep ninja ninja-build

    run_quiet_with_status "LLVM BUILD [$(basename "$ktest_test")]" "DONE" build_llvm

    # Repoint every subsequent kernel/lustre/zfs/nvidia build at the fresh
    # toolchain; map_clang_version turns the path into LLVM=<bin>/ for kbuild.
    ktest_compiler="$ktest_llvm_build/bin/clang"
    export CC="$ktest_compiler"
    export PATH="$ktest_llvm_build/bin:$PATH"

    echo "LLVM VERSION: $("$ktest_compiler" --version | head -n1)"

    # The kernel build wraps $ktest_compiler in ccache, whose default
    # compiler check is mtime -- always fresh here, so every object would
    # miss.  Hash the binary instead: identical rebuilds keep their hits.
    export CCACHE_COMPILERCHECK=content
}

function build_zfs()
{
    local old="$PWD"
    local LINUX_OBJ="/tmp/ktest-out/kernel_build.x86_64/"

    build_zfs_full

    cd "$ktest_zfs_build"

    # Now reconfigure with --enable-linux-builtin for copy-builtin
    export ARCH="$(uname -m)"
    export LLVM="$(map_clang_version)"

    ./configure \
        --with-linux="$ktest_kernel_source" \
        --with-linux-obj="$LINUX_OBJ" \
        --enable-linux-experimental \
        --enable-linux-builtin

    cd "$old"
}

function run_zfs_copy_builtin()
{
    local old="$PWD"
    local patch_output_dir="/tmp/ktest-output"

    mkdir -p "$patch_output_dir"

    cd "$ktest_zfs_build"

    # Ensure zfs_gitrev.h exists before copy-builtin (make clean may delete it)
    if [[ ! -f include/zfs_gitrev.h ]]; then
        local gitrev="unknown"
        if command -v git &> /dev/null && git rev-parse --git-dir &> /dev/null; then
            gitrev=$(git describe --always --long --dirty 2>/dev/null || echo "unknown")
        fi
        mkdir -p include
        printf '#define\tZFS_META_GITREV "%s"\n' "$gitrev" > include/zfs_gitrev.h
    fi

    ./copy-builtin "$ktest_kernel_source"
    cp "$ktest_zfs_build/module/Module.symvers" "$ktest_kernel_source/fs/zfs/"

    # Ensure zfs_gitrev.h exists in include/zfs/
    if [[ ! -f "$ktest_kernel_source/include/zfs/zfs_gitrev.h" ]]; then
        echo "Warning: zfs_gitrev.h not found in kernel tree, creating it"
        printf '#define\tZFS_META_GITREV "unknown"\n' > "$ktest_kernel_source/include/zfs/zfs_gitrev.h"
    fi

    # Copy zfs_gitrev.h to source directories that use #include "zfs_gitrev.h"
    # (quoted includes search the source file's directory first)
    cp "$ktest_kernel_source/include/zfs/zfs_gitrev.h" "$ktest_kernel_source/fs/zfs/zfs/"
    cp "$ktest_kernel_source/include/zfs/zfs_gitrev.h" "$ktest_kernel_source/fs/zfs/os/linux/spl/"

    cd "$ktest_kernel_source"
    git add *
    git add fs/zfs/
    git add -f fs/zfs/Kbuild
    git add include/zfs/
    git commit -m "ZFS"
    git format-patch HEAD~1 --stdout > "$ktest_out/zfs.patch"

    # Copy patch to output directory
    cp "$ktest_out/zfs.patch" "$patch_output_dir/"

    cd "$old"
}

function cmd_generate_zfs_patch()
{
    if [[ $# = 0 ]]; then
	ktest_test="$ktest_boot_test"
    else
	ktest_test=$(realpath "$1")
	shift
    fi

    ktest_testargs="$@"
    parse_test_deps "$ktest_test"

    if [[ -n $COVERAGE ]]; then
	ktest_kernel_config_require+=(GCOV_KERNEL)
    fi

    maybe_build_llvm
    run_quiet_with_status "KERNEL BUILD [$(basename "$ktest_test")]" "DONE" build_kernel
    run_quiet_with_status "ZFS BUILD [$(basename "$ktest_test")]" "DONE" build_zfs

    run_zfs_copy_builtin
}

function cmd_ccplugin()
{
    if [[ $# = 0 ]]; then
	ktest_test="$ktest_boot_test"
    else
	ktest_test=$(realpath "$1")
	shift
    fi

    ktest_testargs="$@"
    parse_test_deps "$ktest_test"

    maybe_build_llvm
    run_quiet_with_status "KERNEL BUILD [$(basename "$ktest_test")]" "DONE" build_kernel
    run_quiet_with_status "LUSTRE BUILD [$(basename "$ktest_test")]" "DONE" build_lustre

    if [[ ! -f "$ktest_lustre_build/compile_commands.json" ]]; then
	echo "compile_commands.json not found at $ktest_lustre_build/compile_commands.json"
	exit 1
    fi

    if [[ ! -x "$ktest_ccplugin" ]]; then
	echo "cc-plugin binary not found at $ktest_ccplugin"
	exit 1
    fi

    # Extra plugin options forwarded from podman-ktest job --plugin-args
    local plugin_args=()
    if [[ -n "${KTEST_CCPLUGIN_ARGS:-}" ]]; then
	read -ra plugin_args <<< "$KTEST_CCPLUGIN_ARGS"
    fi

    echo "PLUGIN"
    "$ktest_ccplugin" "${plugin_args[@]}" "$ktest_lustre_build/compile_commands.json"
}

# Install the freshly-built lustre/zfs kernel modules into the kernel's
# /lib/modules/<release> tree so they get bundled into the initramfs (via
# mk_initramfs --modules) and resolve under modprobe(8) in the VM.  Runs after
# the kernel's own modules_install, so depmod here regenerates modules.dep with
# the kernel + lustre + zfs modules together.
function install_fs_modules()
{
    local kernel_version moddir
    kernel_version=$(cat "$ktest_kernel_build/include/config/kernel.release")
    moddir="$ktest_kernel_binary/lib/modules/$kernel_version/updates"
    mkdir -p "$moddir"

    # Skip kconftest.results/: autoconf's kernel feature probes leave many
    # identically-named conftest.ko there, which would collide in $moddir.
    find "$ktest_lustre_build" -name kconftest.results -prune -o \
	\( -name '*.ko' ! -name 'conftest.ko' \) -exec cp -t "$moddir" {} +
    if [[ "$FSTYPE" == "zfs" && -d "$ktest_zfs_build" ]]; then
	find "$ktest_zfs_build" -name kconftest.results -prune -o \
	    \( -name '*.ko' ! -name 'conftest.ko' \) -exec cp -t "$moddir" {} +
    fi

    # NVIDIA modules build under kernel-open/ (conftest.ko there are feature
    # probes, same as lustre/zfs - skip them).
    if [[ "$ktest_nvidia" == "1" && -d "$ktest_nvidia_build" ]]; then
	find "$ktest_nvidia_build/kernel-open" \
	    \( -name '*.ko' ! -name 'conftest.ko' \) -exec cp -t "$moddir" {} +
    fi

    "$DEPMOD" -b "$ktest_kernel_binary" "$kernel_version"
}

function cmd_build()
{
    if [[ $# = 0 ]]; then
	ktest_test="$ktest_boot_test"
    else
	ktest_test=$(realpath "$1")
	shift
    fi

    ktest_testargs="$@"
    parse_test_deps "$ktest_test"

    if [[ -n $COVERAGE ]]; then
	ktest_kernel_config_require+=(GCOV_KERNEL)
    fi

    maybe_build_llvm
    run_quiet_with_status "KERNEL BUILD [$(basename "$ktest_test")]" "DONE" build_kernel

    if [[ "$FSTYPE" == "zfs" ]]; then
	 run_quiet_with_status "ZFS BUILD [$(basename "$ktest_test")]" "DONE" build_zfs_full
    fi
    if [[ "$ktest_lustre" != "0" ]]; then
	run_quiet_with_status "LUSTRE BUILD [$(basename "$ktest_test")]" "DONE" build_lustre
    fi

    if [[ "$ktest_nvidia" == "1" ]]; then
	run_quiet_with_status "NVIDIA BUILD [$(basename "$ktest_test")]" "DONE" build_nvidia
    fi

    # Drop build intermediates from the lustre/zfs/nvidia trees so the initramfs
    # only carries the modules, libraries, and binaries the VM actually uses.
    purge_build_junk "$ktest_lustre_build"
    [[ "$FSTYPE" == "zfs" ]] && purge_build_junk "$ktest_zfs_build"
    [[ "$ktest_nvidia" == "1" ]] && purge_build_junk "$ktest_nvidia_build"

    run_quiet_with_status "INSTALL FS MODULES [$(basename "$ktest_test")]" "DONE" install_fs_modules
    run_quiet_with_status "INITRAMFS [$(basename "$ktest_test")]" "DONE" build_initramfs
    run_quiet_with_status "UKI [$(basename "$ktest_test")]" "DONE" build_uki

    # The UKI now self-contains kernel + initramfs + modules.  Strip
    # ktest_out down to just that file so the build→run tarball stays small.
    local uki_keep
    uki_keep=$(mktemp)
    mv "$ktest_kernel_binary/uki.efi" "$uki_keep"
    rm -rf "${ktest_out:?}"/*
    mkdir -p "$ktest_kernel_binary"
    mv "$uki_keep" "$ktest_kernel_binary/uki.efi"
}

# Build only the kernel, with the compiler output streamed to stdout instead of
# hidden behind run_quiet_with_status.  Handy for iterating on kernel config /
# compile errors without waiting on the full lustre/zfs/initramfs/uki pipeline.
function cmd_kbuild()
{
    if [[ $# = 0 ]]; then
	ktest_test="$ktest_boot_test"
    else
	ktest_test=$(realpath "$1")
	shift
    fi

    ktest_testargs="$@"
    parse_test_deps "$ktest_test"

    if [[ -n $COVERAGE ]]; then
	ktest_kernel_config_require+=(GCOV_KERNEL)
    fi

    maybe_build_llvm

    # Run build_kernel directly (not via run_quiet_with_status) so the build
    # output is visible in the job log.
    build_kernel
}

function prepare_linux_source()
{
    local old="$PWD"

    cd "$ktest_kernel_source"

    # Apply ZFS patch if it exists (must be applied before Lustre)
    if [[ -f "$ktest_out/zfs.patch" ]]; then
	if [[ -d "$ktest_kernel_source/fs/zfs" ]]; then
	    echo "ZFS patch already applied, skipping..."
	else
	    echo "Applying ZFS patch..."
	    git am "$ktest_out/zfs.patch"
	fi
    fi

    # Apply Lustre patch
    if [[ -d "$ktest_kernel_source/fs/lustre" ]]; then
	echo "Lustre patch already applied, skipping..."
    else
	echo "Applying Lustre patch..."
	git am "$ktest_out/lustre.patch"
    fi

    cd "$old"

    # Save patches to /tmp so purge_previous_results doesn't delete them;
    # restore them afterwards so generate_coverage can apply them in the
    # run container for lcov source annotation.
    if [[ -f "$ktest_out/lustre.patch" ]]; then cp "$ktest_out/lustre.patch" /tmp/lustre.patch; fi
    if [[ -f "$ktest_out/zfs.patch" ]];    then cp "$ktest_out/zfs.patch"    /tmp/zfs.patch;    fi

    purge_previous_results

    if [[ -f /tmp/lustre.patch ]]; then mv /tmp/lustre.patch "$ktest_out/lustre.patch"; fi
    if [[ -f /tmp/zfs.patch ]];    then mv /tmp/zfs.patch    "$ktest_out/zfs.patch";    fi
}

function validate_zfs_build() {
    local lib_dirs=(
	"$ktest_zfs_build/.libs"
	"$ktest_zfs_build/lib/libzfs/.libs"
	"$ktest_zfs_build/lib/libzfs_core/.libs"
	"$ktest_zfs_build/lib/libnvpair/.libs"
	"$ktest_zfs_build/lib/libzpool/.libs"
    )

    local found=0
    for dir in "${lib_dirs[@]}"; do
	[[ -d "$dir" ]] || continue
	for lib in "$dir"/*.so*; do
	    [[ -e "$lib" ]] || continue
	    found=1
	    break 2
	done
    done

    if [[ $found -eq 0 ]]; then
	echo "ZFS shared libraries not found in $ktest_zfs_build!"
	exit 1
    fi

    # Check for ZFS kernel module (post-2.3.0 layout)
    if [[ -f "$ktest_zfs_build/module/zfs.ko" ]]; then
	return 0
    fi

    # Check for ZFS kernel module (pre-2.3.0 layout)
    check_file "$ktest_zfs_build/module/zfs/zfs.ko"
}

function validate_native_zfs_build() {
    check_file "$ktest_kernel_build/fs/zfs/zfs.ko"
    check_file "$ktest_kernel_build/fs/zfs/spl.ko"
