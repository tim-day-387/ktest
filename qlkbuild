function cmd_generate_lustre_patch()
{
    if [[ $# = 0 ]]; then
	ktest_test="$ktest_boot_test"
    else
	ktest_test=$(realpath "$1")
	shift
    fi

    ktest_testargs="$@"
    parse_test_deps "$ktest_test"

    if [[ -n $COVERAGE ]]; then
	ktest_kernel_config_require+=(GCOV_KERNEL)
    fi


    # Use cached lustre_config.h from the kernel tree if available,
    # otherwise run full Lustre configure to generate one.
    if [[ -f "$ktest_kernel_source/lustre_config.h" ]]; then
	echo "Using cached lustre_config.h from kernel tree"
    else
	maybe_build_llvm
	run_quiet_with_status "KERNEL BUILD [$(basename "$ktest_test")]" "DONE" build_kernel
	run_quiet_with_status "LUSTRE BUILD [$(basename "$ktest_test")]" "DONE" build_lustre_intree
    fi

    run_copy_builtin
}

