#!/usr/bin/env bash
#
# Create a VM image suitable for running automated tests
# Output: vm_image

set -o nounset
set -o errexit
set -o errtrace

ktest_dir=$(dirname "$(readlink -f "$0")")
debootstrap=$ktest_dir/debootstrap/debootstrap

. "$ktest_dir/lib/util.sh"
. "$ktest_dir/lib/common.sh"

if [[ $(id -u) != 0 && "$1" != "sync" ]] ; then
    echo this script must be run as root
    exit 1
fi

checkdep fallocate util-linux
checkdep mkfs.ext4 e2fsprogs
checkdep curl

# ZFS pool and dataset names for Lustre
LUSTRE_POOL="lustre_pool"
LUSTRE_MGS_DS="mgs_mdt"
LUSTRE_OST0_DS="ost0"
LUSTRE_OST1_DS="ost1"
LUSTRE_FSNAME="lustre"
LUSTRE_CLIENT_MNT="/mnt/lustre" 

IMAGE_SIZE="16G"
MIRROR=https://deb.debian.org/debian/
RELEASE=sid

usage()
{
    echo "root_image: create/update virtual machine root images for ktest"
    echo "Usage: root_image cmd [options]"
    echo "  create		Create a new image"
    echo "  create_lustre	Create a new image on Lustre (ZFS backend)"
    echo "  create_usb		Create a bootable USB image (EFI/GRUB)"
    echo "  update		Update an existing image"
    echo "  sync		Copy directory to an existing image"
    echo "  mount_lustre	Mount an existing Lustre image"
    echo "  umount_lustre	Unmount a Lustre image"
    echo
    echo "options:"
    echo "  -h			Display this help and exit"
    echo "  -a <arch>		Architecture for vm image"
    echo "  -m <mirror>		Debian mirror"
    echo '  -i <image>		Image to create/update, defaults to /var/lib/ktest/root.$arch'
    echo "  -k <dir>		Directory containing kernel .deb packages and/or a vmlinuz file (for create_usb)"
}

if [[ $# = 0 ]]; then
    usage
    exit 1
fi

ktest_image=""
ktest_kernel_debs=""
CMD="cmd_$1"
shift

while getopts "ha:m:i:k:" arg; do
    case $arg in
	h)
	    usage
	    exit 0
	    ;;
	a)
	    ktest_arch=$OPTARG
	    ;;
	m)
	    MIRROR=$OPTARG
	    ;;
	i)
	    ktest_image=$OPTARG
	    ;;
	k)
	    ktest_kernel_debs=$OPTARG
	    ;;
    esac
done
shift $(( OPTIND - 1 ))

parse_arch "$ktest_arch"

[[ -z $ktest_image ]] && ktest_image=/var/lib/ktest/root.$DEBIAN_ARCH

mkdir -p "$(dirname "$ktest_image")"

