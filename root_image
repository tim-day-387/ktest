#!/usr/bin/env bash
#
# Build ktest VM root images.
#

set -o nounset
set -o errexit
set -o errtrace

ktest_dir=$(dirname "$(readlink -f "$0")")

. "$ktest_dir/lib/util.sh"
. "$ktest_dir/lib/common.sh"

if [[ $(id -u) != 0 ]] ; then
    echo this script must be run as root
    exit 1
fi

checkdep podman
checkdep fallocate util-linux
checkdep mkfs.ext4 e2fsprogs

# Container image refs. The base image (Containerfile.root_image) carries the
# common Lustre-root foundation; the ktest and desktop images are built FROM
# it (Containerfile.ktest / Containerfile.desktop).
ROOT_BASE_TAG=${ROOT_BASE_TAG:-localhost/ktest-root-base:latest}
ROOT_IMAGE_TAG=${ROOT_IMAGE_TAG:-localhost/ktest-root:latest}
DESKTOP_IMAGE_TAG=${DESKTOP_IMAGE_TAG:-localhost/ktest-desktop:latest}
ROOT_IMAGE_BASE=${ROOT_IMAGE_BASE:-docker.io/library/ubuntu:24.04}

CONTAINERFILE_BASE="$ktest_dir/containers/Containerfile.root_image"
CONTAINERFILE_KTEST="$ktest_dir/containers/Containerfile.ktest"
CONTAINERFILE_DESKTOP="$ktest_dir/containers/Containerfile.desktop"

# ZFS pool and dataset names for Lustre (unchanged from the old script;
# mount_lustre / umount_lustre still operate on these names).
LUSTRE_POOL="lustre_pool"
LUSTRE_MGS_DS="mgs_mdt"
LUSTRE_OST0_DS="ost0"
LUSTRE_OST1_DS="ost1"
LUSTRE_FSNAME="lustre"
LUSTRE_CLIENT_MNT="/mnt/lustre"

IMAGE_SIZE="16G"

usage()
{
    echo "root_image: create ktest virtual-machine root images"
    echo "Usage: root_image cmd [options]"
    echo "  create		Create a new raw ext4 root image"
    echo "  create_lustre	Create a new ktest image on Lustre (ZFS backend); prints"
    echo "  			manual steps for deploying it to a bootable USB"
    echo "  create_lustre_desktop	Like create_lustre, but a full GNOME desktop"
    echo "  			image (see containers/Containerfile.desktop, ~/USER.md)"
    echo "  mount_lustre	Mount an existing Lustre image"
    echo "  umount_lustre	Unmount a Lustre image"
    echo
    echo "options:"
    echo "  -h			Display this help and exit"
    echo "  -a <arch>		Architecture for vm image"
    echo '  -i <image>		Image to create, defaults to /var/lib/ktest/root.$arch'
    echo "  -u <user>		Seed an interactive login user (for create_lustre)"
}

if [[ $# = 0 ]]; then
    usage
    exit 1
fi

ktest_image=""
ktest_usb_username=""
CMD="cmd_$1"
shift

while getopts "ha:i:u:" arg; do
    case $arg in
	h) usage; exit 0 ;;
	a) ktest_arch=$OPTARG ;;
	i) ktest_image=$OPTARG ;;
	u) ktest_usb_username=$OPTARG ;;
    esac
done
shift $(( OPTIND - 1 ))

parse_arch "$ktest_arch"

[[ -z $ktest_image ]] && ktest_image=/var/lib/ktest/root.$DEBIAN_ARCH
mkdir -p "$(dirname "$ktest_image")"

# ----- container build helpers -------------------------------------------

# Build the shared base container image. Idempotent — re-runs use podman's
# layer cache, so a no-op rebuild is fast.
build_base_image()
{
    echo "Building base container image ($ROOT_BASE_TAG)..."
    podman build \
	--build-arg "BASE=$ROOT_IMAGE_BASE" \
	-f "$CONTAINERFILE_BASE" \
	-t "$ROOT_BASE_TAG" \
	"$ktest_dir"
}

# Build a variant image (ktest or desktop) on top of the base. Builds the
# base first; podman's layer cache makes the base rebuild a no-op once warm.
build_variant_image()
{
    local containerfile=$1 tag=$2

    build_base_image

    echo "Building container image ($tag)..."
    podman build \
	--build-arg "ROOT_BASE=$ROOT_BASE_TAG" \
	-f "$containerfile" \
	-t "$tag" \
	"$ktest_dir"
}

# The ktest test-VM image. Named build_root_image so cmd_create (which builds
# the ext4 root) keeps using it unchanged.
build_root_image()
{
    build_variant_image "$CONTAINERFILE_KTEST" "$ROOT_IMAGE_TAG"
}

# The desktop dogfooding image.
build_desktop_image()
{
    build_variant_image "$CONTAINERFILE_DESKTOP" "$DESKTOP_IMAGE_TAG"
}

# Extract the contents of an OCI image into $dest using podman export.
extract_image_to()
{
    local image=$1 dest=$2
    local cid
    cid=$(podman create "$image" /bin/true)
    # --xattrs-include: plain tar -x silently drops security.capability (and
    # everything outside user.*), and snapd >= 2.68 ships snap-confine with
    # file capabilities instead of setuid root, so snaps can't start without
    # it.
    podman export "$cid" | tar -C "$dest" --xattrs --xattrs-include='*' -xf -
    podman rm "$cid" >/dev/null

    # /etc/resolv.conf can't be baked into the image: podman bind-mounts it
    # during build, so RUN-writes never persist and the export ships the base
    # image's empty file. Point it at the systemd-resolved stub (the standard
    # Ubuntu arrangement) so NetworkManager/networkd DNS actually resolves.
    ln -sfn ../run/systemd/resolve/stub-resolv.conf "$dest/etc/resolv.conf"
}

# ----- cmd_create --------------------------------------------------------

cmd_create()
{
    if [[ -e $ktest_image ]]; then
	echo "Removing existing $ktest_image"
	rm -f "$ktest_image"
    fi

    build_root_image

    # Extract the image into a directory, then build the ext4 filesystem
    # straight from that tree with mke2fs -d. This needs no loop mount, so it
    # works unprivileged and inside a rootless container, where setting up a
    # loop device is not permitted. Both the extraction and mke2fs run in the
    # same user namespace, so ownership is recorded with the right uids.
    # rootfs is deliberately not 'local' so the EXIT trap can see it.
    rootfs=$(mktemp --tmpdir -d root_image-rootfs-XXXXXXXXXX)
    trap 'rm -rf "$rootfs"; rm -f "$ktest_image".new' EXIT

    echo "Extracting root image..."
    extract_image_to "$ROOT_IMAGE_TAG" "$rootfs"

    # Sparse file: mke2fs writes only metadata and used blocks, the rest stay
    # holes - so the image stays compact despite IMAGE_SIZE.
    truncate -s "$IMAGE_SIZE" "$ktest_image".new
    chmod 644 "$ktest_image".new
    mkfs.ext4 -q -F -d "$rootfs" "$ktest_image".new

    e2fsck -fy "$ktest_image".new >/dev/null || true

    rm -rf "$rootfs"
    trap '' EXIT
    mv "$ktest_image".new "$ktest_image"
    echo "Created $ktest_image"
}

# ----- Lustre helpers (unchanged from the old script) --------------------

_umount_lustre_client()
{
    sync
    umount --recursive "$LUSTRE_CLIENT_MNT" 2>/dev/null && return 0
    umount -f --recursive "$LUSTRE_CLIENT_MNT" 2>/dev/null && return 0
    return 1
}

_export_lustre()
{
    set +e
    zpool export "$LUSTRE_POOL" 2>/dev/null
    set -e
}

_clean_lustre()
{
    set +e
    if ! _umount_lustre_client; then set -e; return 1; fi
    sync
    umount /mnt/lustre-ost1 2>/dev/null
    umount /mnt/lustre-ost0 2>/dev/null
    umount /mnt/lustre-mgs  2>/dev/null
    _export_lustre
    set -e
}

_cleanup_lustre_mount()
{
    _clean_lustre
    rm -f "$ktest_image".new
}

umount_lustre_image()
{
    _clean_lustre
    trap '' EXIT
    mv "$ktest_image".new "$ktest_image"
}

mount_lustre_image()
{
    if [[ ! -e $ktest_image ]]; then
	echo "$ktest_image does not exist"
	exit 1
    fi

    command -v zpool &>/dev/null || { echo "zpool not found - install ZFS"; exit 1; }

    if zpool list "$LUSTRE_POOL" &>/dev/null; then
	echo "Cleaning up existing ZFS pool '$LUSTRE_POOL' from previous run..."
	_export_lustre
    fi

    trap '_cleanup_lustre_mount' EXIT

    modprobe lustre
    modprobe zfs

    cp "$ktest_image" "$ktest_image".new

    zpool import -d "$(dirname "$ktest_image".new)" "$LUSTRE_POOL"

    mkdir -p /mnt/lustre-mgs /mnt/lustre-ost0 /mnt/lustre-ost1
    mount -t lustre "$LUSTRE_POOL/$LUSTRE_MGS_DS"  /mnt/lustre-mgs
    mount -t lustre "$LUSTRE_POOL/$LUSTRE_OST0_DS" /mnt/lustre-ost0
    mount -t lustre "$LUSTRE_POOL/$LUSTRE_OST1_DS" /mnt/lustre-ost1

    local fsname=$(zfs get -H -o value lustre:fsname "$LUSTRE_POOL/$LUSTRE_MGS_DS")
    [[ -z $fsname || $fsname = - ]] && fsname=$LUSTRE_FSNAME

    local mgs_nid=$(lnetctl net show | grep 'nid:.*@tcp' | head -1 | awk '{print $NF}')
    mkdir -p "$LUSTRE_CLIENT_MNT"
    mount -t lustre "$mgs_nid:/$fsname" "$LUSTRE_CLIENT_MNT"

    MNT="$LUSTRE_CLIENT_MNT"
}

cmd_mount_lustre()
{
    mount_lustre_image
    echo "Lustre image mounted at $LUSTRE_CLIENT_MNT"
    echo "Servers mounted at /mnt/lustre-mgs, /mnt/lustre-ost0, /mnt/lustre-ost1"
    trap '' EXIT
}

cmd_umount_lustre()
{
    if ! zpool list "$LUSTRE_POOL" &>/dev/null; then
	echo "ZFS pool '$LUSTRE_POOL' is not imported"
	exit 1
    fi
    umount_lustre_image
    echo "Lustre image unmounted and exported"
}

# ----- cmd_create_lustre -------------------------------------------------

# Shared implementation for create_lustre and create_lustre_desktop. Builds
# the requested container image, lays down a fresh Lustre filesystem on a
# ZFS-backed image file, extracts the image into the client mount, and seeds
# an optional login user.
#   $1 - build function to run (build_root_image / build_desktop_image)
#   $2 - container image tag to extract from
_create_lustre_image()
{
    local build_fn=$1 image_tag=$2

    if [[ -e $ktest_image ]]; then
	echo "$ktest_image already exists"
	exit 1
    fi

    command -v zpool      &>/dev/null || { echo "zpool not found - install ZFS"; exit 1; }
    command -v mkfs.lustre &>/dev/null || { echo "mkfs.lustre not found - install Lustre"; exit 1; }

    if zpool list "$LUSTRE_POOL" &>/dev/null; then
	echo "Cleaning up existing ZFS pool '$LUSTRE_POOL' from previous run..."
	_export_lustre
    fi

    "$build_fn"

    trap '_cleanup_lustre_mount' EXIT

    modprobe lustre
    modprobe zfs

    fallocate -l "$IMAGE_SIZE" "$ktest_image".new
    chmod 644 "$ktest_image".new

    zpool create -f "$LUSTRE_POOL" "$ktest_image".new

    zfs create -o mountpoint=none "$LUSTRE_POOL/$LUSTRE_MGS_DS"
    zfs create -o mountpoint=none "$LUSTRE_POOL/$LUSTRE_OST0_DS"
    zfs create -o mountpoint=none "$LUSTRE_POOL/$LUSTRE_OST1_DS"

    mkfs.lustre --mgs --mdt --reformat --fsname="$LUSTRE_FSNAME" --index=0 \
	"$LUSTRE_POOL/$LUSTRE_MGS_DS"

    local mgs_nid=$(lnetctl net show | grep 'nid:.*@tcp' | head -1 | awk '{print $NF}')
    mkfs.lustre --ost --reformat --fsname="$LUSTRE_FSNAME" --index=0 \
	--mgsnode="$mgs_nid" "$LUSTRE_POOL/$LUSTRE_OST0_DS"
    mkfs.lustre --ost --reformat --fsname="$LUSTRE_FSNAME" --index=1 \
	--mgsnode="$mgs_nid" "$LUSTRE_POOL/$LUSTRE_OST1_DS"

    mkdir -p /mnt/lustre-mgs /mnt/lustre-ost0 /mnt/lustre-ost1
    mount -t lustre "$LUSTRE_POOL/$LUSTRE_MGS_DS"  /mnt/lustre-mgs
    mount -t lustre "$LUSTRE_POOL/$LUSTRE_OST0_DS" /mnt/lustre-ost0
    mount -t lustre "$LUSTRE_POOL/$LUSTRE_OST1_DS" /mnt/lustre-ost1

    # MDT must be tuned before MDC, otherwise MDC rejects the higher cap.
    lctl set_param mdt.*.max_mod_rpcs_in_flight=128

    mkdir -p "$LUSTRE_CLIENT_MNT"
    mount -t lustre "$mgs_nid:/$LUSTRE_FSNAME" "$LUSTRE_CLIENT_MNT"

    # Hybrid IO interacts badly with the large untar we're about to do.
    lctl set_param llite.*.hybrid_io=0
    lctl set_param mdc.*.max_rpcs_in_flight=256
    lctl set_param mdc.*.max_mod_rpcs_in_flight=128
    lctl set_param osc.*.max_rpcs_in_flight=256

    echo "Extracting root image into Lustre client mount..."
    extract_image_to "$image_tag" "$LUSTRE_CLIENT_MNT"

    # Optional interactive login user (was the point of the old create_usb).
    # The username comes from -u so it can't be baked into the Containerfile.
    if [[ -n $ktest_usb_username ]]; then
	echo "Creating user $ktest_usb_username..."
	chroot "$LUSTRE_CLIENT_MNT" useradd -m -s /bin/bash -G sudo "$ktest_usb_username"
	chroot "$LUSTRE_CLIENT_MNT" passwd -d "$ktest_usb_username"
    fi

    echo "Unmounting Lustre..."
    _clean_lustre
    trap '' EXIT
    mv "$ktest_image".new "$ktest_image"
    echo "Created $ktest_image"
    echo "To deploy this image to a bootable USB stick, see" \
	"$ktest_dir/Documentation/usb-boot.md"
}

cmd_create_lustre()
{
    _create_lustre_image build_root_image "$ROOT_IMAGE_TAG"
}

cmd_create_lustre_desktop()
{
    # Lustre fsnames are limited to 8 characters
    LUSTRE_FSNAME="$(od -An -N4 -tx1 /dev/urandom | tr -d ' \n')"
    _create_lustre_image build_desktop_image "$DESKTOP_IMAGE_TAG"
}

if [[ $(type -t "$CMD") != function ]]; then
    usage
    exit 1
fi

$CMD "$@"
