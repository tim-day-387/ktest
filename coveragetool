#!/usr/bin/env bash

set -o nounset
set -o errexit

ktest_out="./ktest-out"

usage()
{
    echo "coveragetool: Generate lcov code profiling report"
    echo "Usage: coveragetool [options]"
    echo "      -o <dir>        output directory; defaults to ./ktest-out"
    echo "      -h              display this help and exit"
}

while getopts "o:h" arg; do
    case $arg in
	o)
	    ktest_out=$OPTARG
	    ;;
	h)
	    usage
	    exit 0
	    ;;
    esac
done
shift $(( OPTIND - 1 ))

if [ "$#" -ne 0 ]; then
    ktest_out=$1
fi

ktest_out=$(readlink -f "$ktest_out")

if ! which lcov > /dev/null; then
    echo "lcov not installed"
    exit 0
fi

# When the kernel is compiled with clang, read the gcov data with llvm-cov.
# Prefer the llvm-cov matching $CC (e.g. clang-22 -> llvm-cov-22) so the reader
# understands the exact .gcno/.gcda format clang wrote; fall back to the newest
# llvm-cov available (with a warning) rather than aborting the whole run.
gcov_tool_opt=()
if [[ "${CC:-}" =~ clang-([0-9]+) ]]; then
    ver="${BASH_REMATCH[1]}"
    llvm_cov=""
    if command -v "llvm-cov-$ver" > /dev/null 2>&1; then
        llvm_cov="llvm-cov-$ver"
    elif command -v llvm-cov > /dev/null 2>&1 &&
         llvm-cov --version 2>/dev/null | grep -qE "version $ver\."; then
        llvm_cov="llvm-cov"
    else
        for c in llvm-cov-{40..14} llvm-cov; do
            command -v "$c" > /dev/null 2>&1 && { llvm_cov="$c"; break; }
        done
        [ -n "$llvm_cov" ] && echo "coveragetool: warning: llvm-cov-$ver" \
            "(matching $CC) not found; using $llvm_cov - coverage may be" \
            "approximate" >&2
    fi
    if [ -z "$llvm_cov" ]; then
        echo "coveragetool: no llvm-cov found to read $CC gcov data" >&2
        exit 1
    fi
    wrapper=$(mktemp /tmp/gcov-wrapper.XXXXXX)
    printf '#!/bin/sh\nexec %s gcov "$@"\n' "$llvm_cov" > "$wrapper"
    chmod +x "$wrapper"
    trap "rm -f $wrapper" EXIT
    gcov_tool_opt=(--gcov-tool "$wrapper")
fi

# lcov 2.x promotes several llvm-cov quirks to fatal errors. llvm-cov gcov does
# not emit gcc-9 function begin/end line records, so lcov *derives* them and
# then its own consistency check rejects a function whose entry line reads as
# not-hit while a body line is hit ("function 'foo' is not hit but line N is").
# These are metadata artifacts, not wrong counts - tell lcov to warn and keep
# going instead of aborting the report.
lcov_ignore=(--ignore-errors gcov,unsupported,inconsistent,corrupt,range,mismatch)
genhtml_ignore=(--ignore-errors inconsistent,corrupt,range,unsupported)

lcov_out="$ktest_out/lcov"

info=$lcov_out/lcov.info
html=$lcov_out/lcov.html
tracefiles=""

echo "lcov_out=$lcov_out"
mkdir -p "$lcov_out"

n=0

for dir in $ktest_out/gcov.*; do
    out=$lcov_out/lcov.${n}.info
    tracefiles+=" --add-tracefile $out"

    lcov --capture --quiet "${gcov_tool_opt[@]}" "${lcov_ignore[@]}" \
        --directory "$dir" --output-file "$out"

    n=$((n+1))
done

[ -n "$tracefiles" ] || exit 0

lcov --quiet "${lcov_ignore[@]}" --output-file "$info" $tracefiles
genhtml "${genhtml_ignore[@]}" --output-directory "$html" "$info"

echo
echo "LCOV report: file://$html/index.html"
