#!/usr/bin/env bash

set -o nounset
set -o errexit

ktest_out="./ktest-out"

usage()
{
    echo "coveragetool: Generate lcov code profiling report"
    echo "Usage: coveragetool [options]"
    echo "      -o <dir>        output directory; defaults to ./ktest-out"
    echo "      -h              display this help and exit"
}

while getopts "o:h" arg; do
    case $arg in
	o)
	    ktest_out=$OPTARG
	    ;;
	h)
	    usage
	    exit 0
	    ;;
    esac
done
shift $(( OPTIND - 1 ))

if [ "$#" -ne 0 ]; then
    ktest_out=$1
fi

ktest_out=$(readlink -f "$ktest_out")

if ! which lcov > /dev/null; then
    echo "lcov not installed"
    exit 0
fi

# When the kernel is compiled with clang, use llvm-cov gcov to avoid
# gcov format version mismatches between clang output and the system gcov.
gcov_tool_opt=()
for v in "" -20 -19 -18 -17; do
    if command -v "llvm-cov$v" > /dev/null 2>&1; then
        wrapper=$(mktemp /tmp/gcov-wrapper.XXXXXX)
        printf '#!/bin/sh\nexec llvm-cov%s gcov "$@"\n' "$v" > "$wrapper"
        chmod +x "$wrapper"
        trap "rm -f $wrapper" EXIT
        gcov_tool_opt=(--gcov-tool "$wrapper")
        break
    fi
done

lcov_out="$ktest_out/lcov"

info=$lcov_out/lcov.info
html=$lcov_out/lcov.html
tracefiles=""

echo "lcov_out=$lcov_out"
mkdir -p "$lcov_out"

n=0

for dir in $ktest_out/gcov.*; do
    out=$lcov_out/lcov.${n}.info
    tracefiles+=" --add-tracefile $out"

    lcov --capture --quiet "${gcov_tool_opt[@]}" \
        --directory "$dir" --output-file "$out"

    n=$((n+1))
done

[ -n "$tracefiles" ] || exit 0

lcov --quiet --output-file "$info" $tracefiles
genhtml --output-directory "$html" "$info"

echo
echo "LCOV report: file://$html/index.html"
